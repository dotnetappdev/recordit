<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- OBS Studio Dark Theme - exact colors -->

    <!-- Core backgrounds -->
    <Color x:Key="BgBaseColor">#FF23232A</Color>
    <Color x:Key="BgSurfaceColor">#FF2B2B32</Color>
    <Color x:Key="BgElevatedColor">#FF303037</Color>
    <Color x:Key="BgOverlayColor">#FF353540</Color>
    <Color x:Key="BgHoverColor">#FF3A3A42</Color>
    <Color x:Key="BgActiveColor">#FF454550</Color>
    <Color x:Key="BgPanelColor">#FF23232A</Color>
    <Color x:Key="BgPanelHeaderColor">#FF2B2B32</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFECECEC</Color>
    <Color x:Key="TextSecondaryColor">#FFA0A0A8</Color>
    <Color x:Key="TextTertiaryColor">#FF6B6B78</Color>
    <Color x:Key="TextDisabledColor">#FF4A4A58</Color>

    <!-- Borders -->
    <Color x:Key="BorderDefaultColor">#FF3D3D46</Color>
    <Color x:Key="BorderStrongColor">#FF555560</Color>
    <Color x:Key="BorderFocusColor">#FF1666BE</Color>
    <Color x:Key="BorderPanelColor">#FF3D3D46</Color>

    <!-- Accent -->
    <Color x:Key="BrandPrimaryColor">#FF1666BE</Color>
    <Color x:Key="BrandPrimaryHoverColor">#FF1A5FA8</Color>
    <Color x:Key="BrandSecondaryColor">#FF1E538A</Color>
    <Color x:Key="BrandAccentColor">#FF4992FF</Color>
    <Color x:Key="RecordingColor">#FFEF4444</Color>
    <Color x:Key="SuccessColor">#FF22C55E</Color>
    <Color x:Key="WarningColor">#FFF59E0B</Color>
    <Color x:Key="ErrorColor">#FFEF4444</Color>
    <Color x:Key="ActiveBlueBgColor">#FF1666BE</Color>

    <!-- VU -->
    <Color x:Key="VuGreenColor">#FF22C55E</Color>
    <Color x:Key="VuYellowColor">#FFFBBF24</Color>
    <Color x:Key="VuRedColor">#FFEF4444</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrandPrimaryBrush"    Color="{StaticResource BrandPrimaryColor}" />
    <SolidColorBrush x:Key="BrandSecondaryBrush"  Color="{StaticResource BrandSecondaryColor}" />
    <SolidColorBrush x:Key="BgBaseBrush"          Color="{StaticResource BgBaseColor}" />
    <SolidColorBrush x:Key="BgSurfaceBrush"       Color="{StaticResource BgSurfaceColor}" />
    <SolidColorBrush x:Key="BgElevatedBrush"      Color="{StaticResource BgElevatedColor}" />
    <SolidColorBrush x:Key="BgOverlayBrush"       Color="{StaticResource BgOverlayColor}" />
    <SolidColorBrush x:Key="BgHoverBrush"         Color="{StaticResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgPanelBrush"         Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="BgPanelHeaderBrush"   Color="{StaticResource BgPanelHeaderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="BorderDefaultBrush"   Color="{StaticResource BorderDefaultColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush"    Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="BorderPanelBrush"     Color="{StaticResource BorderPanelColor}" />
    <SolidColorBrush x:Key="RecordingBrush"       Color="{StaticResource RecordingColor}" />
    <SolidColorBrush x:Key="SuccessBrush"         Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush"           Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ActiveBlueBgBrush"    Color="{StaticResource ActiveBlueBgColor}" />
    <SolidColorBrush x:Key="VuGreenBrush"         Color="{StaticResource VuGreenColor}" />
    <SolidColorBrush x:Key="VuYellowBrush"        Color="{StaticResource VuYellowColor}" />
    <SolidColorBrush x:Key="VuRedBrush"           Color="{StaticResource VuRedColor}" />

    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource BgBaseColor}" />
    <SolidColorBrush x:Key="NavigationViewContentBackground"     Color="{StaticResource BgBaseColor}" />

    <!-- Typography -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"      Value="11" />
        <Setter Property="FontWeight"    Value="Normal" />
        <Setter Property="Foreground"    Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="CharacterSpacing" Value="0" />
    </Style>

    <!-- Card -->
    <Style x:Key="AlvoniaCardStyle" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource BgSurfaceBrush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="2" />
        <Setter Property="Padding"          Value="12" />
    </Style>

    <!-- Panel container -->
    <Style x:Key="ObsPanelStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BgPanelBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BorderPanelBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Panel header (OBS: same bg as panel, thin bottom border, normal text) -->
    <Style x:Key="ObsPanelHeaderStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BgPanelHeaderBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BorderPanelBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding"         Value="6,0,4,0" />
        <Setter Property="Height"          Value="28" />
    </Style>

    <!-- Panel header text (OBS: normal white text, NOT purple/bold/uppercase) -->
    <Style x:Key="ObsPanelHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="Normal" />
        <Setter Property="Foreground"        Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CharacterSpacing"  Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Panel toolbar -->
    <Style x:Key="ObsPanelToolbarStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BgPanelBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BorderPanelBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding"         Value="2,2" />
        <Setter Property="Height"          Value="26" />
    </Style>

    <!-- Panel separator line -->
    <Style x:Key="PanelSeparatorStyle" TargetType="Rectangle">
        <Setter Property="Fill"    Value="{StaticResource BorderPanelBrush}" />
        <Setter Property="Width"   Value="1" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Primary action button -->
    <Style x:Key="AlvoniaPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Padding"         Value="14,6" />
        <Setter Property="FontWeight"      Value="Normal" />
        <Setter Property="FontSize"        Value="12" />
    </Style>

    <!-- Ghost button (title bar etc) -->
    <Style x:Key="AlvoniaGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="0" />
        <Setter Property="Padding"         Value="10,5" />
    </Style>

    <!-- Record button (OBS: plain dark button like others) -->
    <Style x:Key="AlvoniaRecordButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="{StaticResource BgElevatedBrush}" />
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontWeight"      Value="Normal" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- OBS active/highlighted button (e.g. "Stop Recording" when recording) -->
    <Style x:Key="ObsActiveBlueBtnStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="{StaticResource ActiveBlueBgBrush}" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Padding"         Value="10,5" />
        <Setter Property="FontWeight"      Value="Normal" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- OBS toolbar icon button -->
    <Style x:Key="ObsToolbarBtnStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Width"           Value="22" />
        <Setter Property="Height"          Value="22" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="FontSize"        Value="11" />
    </Style>

    <!-- Sidebar nav button -->
    <Style x:Key="AlvoniaSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Width"           Value="40" />
        <Setter Property="Height"          Value="40" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <!-- Whiteboard tool -->
    <Style x:Key="WbToolButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius"    Value="2" />
        <Setter Property="Width"           Value="36" />
        <Setter Property="Height"          Value="36" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <!-- Mute toggle -->
    <Style x:Key="MuteButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
        <Setter Property="Background"        Value="Transparent" />
        <Setter Property="Foreground"        Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="BorderBrush"       Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="CornerRadius"      Value="2" />
        <Setter Property="Width"             Value="24" />
        <Setter Property="Height"            Value="22" />
        <Setter Property="Padding"           Value="0" />
        <Setter Property="FontSize"          Value="10" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>

    <!-- Controls panel button (OBS style: flat, dark, full-width, 26px tall) -->
    <Style x:Key="ControlsPanelBtnStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background"          Value="{StaticResource BgElevatedBrush}" />
        <Setter Property="Foreground"          Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush"         Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="BorderThickness"     Value="1" />
        <Setter Property="CornerRadius"        Value="2" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding"             Value="10,4" />
        <Setter Property="FontSize"            Value="12" />
        <Setter Property="FontWeight"          Value="Normal" />
        <Setter Property="Height"              Value="26" />
    </Style>

    <!-- OBS Streaming button (blue) -->
    <Style x:Key="ObsStreamButtonStyle" TargetType="Button" BasedOn="{StaticResource ControlsPanelBtnStyle}">
        <Setter Property="Background"      Value="#FF1A72B8" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- OBS Recording button (red) -->
    <Style x:Key="ObsRecordButtonStyle" TargetType="Button" BasedOn="{StaticResource ControlsPanelBtnStyle}">
        <Setter Property="Background"      Value="#FFD71C1C" />
        <Setter Property="Foreground"      Value="White" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ComboBox -->
    <Style x:Key="AlvoniaComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
        <Setter Property="Background"   Value="{StaticResource BgElevatedBrush}" />
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush"  Value="{StaticResource BorderDefaultBrush}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding"      Value="6,3" />
        <Setter Property="FontSize"     Value="12" />
    </Style>

    <!-- ToggleSwitch -->
    <Style x:Key="AlvoniaToggleSwitchStyle" TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
        <Setter Property="OffContent" Value="" />
        <Setter Property="OnContent"  Value="" />
    </Style>

    <!-- Scene/Source list item (OBS: flat, no corner radius) -->
    <Style x:Key="ObsListItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Padding"         Value="6,3" />
        <Setter Property="CornerRadius"    Value="0" />
        <Setter Property="Margin"          Value="0,0" />
        <Setter Property="MinHeight"       Value="22" />
    </Style>

</ResourceDictionary>
