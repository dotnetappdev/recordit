<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.WhiteboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BgBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Toolbar -->
            <RowDefinition Height="Auto" />   <!-- Row 1: Annotation bar (collapsed by default) -->
            <RowDefinition Height="*" />      <!-- Row 2: Canvas area -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Toolbar
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <!-- Drawing Tools -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="SelectToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="select"
                                ToolTipService.ToolTip="Select (V)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B0;" FontSize="16" />
                        </Button>
                        <Button x:Name="PenToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="pen"
                                ToolTipService.ToolTip="Pen (P)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xED63;" FontSize="16" />
                        </Button>
                        <Button x:Name="HighlighterToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="highlighter"
                                ToolTipService.ToolTip="Highlighter (H)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="16" />
                        </Button>
                        <Button x:Name="EraserToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="eraser"
                                ToolTipService.ToolTip="Eraser (E)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xED60;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Shape Tools -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="LineToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="line"
                                ToolTipService.ToolTip="Line">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF576;" FontSize="16" />
                        </Button>
                        <Button x:Name="RectToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="rect"
                                ToolTipService.ToolTip="Rectangle">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C7;" FontSize="16" />
                        </Button>
                        <Button x:Name="CircleToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="circle"
                                ToolTipService.ToolTip="Ellipse">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF137;" FontSize="16" />
                        </Button>
                        <Button x:Name="TextToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="text"
                                ToolTipService.ToolTip="Text">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D2;" FontSize="16" />
                        </Button>
                        <Button x:Name="StickyToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ToolBtn_Click" Tag="sticky"
                                ToolTipService.ToolTip="Sticky Note">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70B;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Pan tool -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <Button x:Name="PanToolBtn" Style="{StaticResource WbToolButtonStyle}"
                            Click="ToolBtn_Click" Tag="pan"
                            ToolTipService.ToolTip="Pan (Space + drag)">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C2;" FontSize="16" />
                    </Button>
                </Border>

                <!-- Color Palette -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <Border x:Name="Color1" Width="22" Height="22" CornerRadius="4"
                                Background="#F5F5F5" BorderBrush="#555" BorderThickness="1"
                                Tapped="ColorSwatch_Tapped" Tag="#F5F5F5" />
                        <Border x:Name="Color2" Width="22" Height="22" CornerRadius="4"
                                Background="#EF4444" Tapped="ColorSwatch_Tapped" Tag="#EF4444" />
                        <Border x:Name="Color3" Width="22" Height="22" CornerRadius="4"
                                Background="#F59E0B" Tapped="ColorSwatch_Tapped" Tag="#F59E0B" />
                        <Border x:Name="Color4" Width="22" Height="22" CornerRadius="4"
                                Background="#22C55E" Tapped="ColorSwatch_Tapped" Tag="#22C55E" />
                        <Border x:Name="Color5" Width="22" Height="22" CornerRadius="4"
                                Background="#06B6D4" Tapped="ColorSwatch_Tapped" Tag="#06B6D4" />
                        <Border x:Name="Color6" Width="22" Height="22" CornerRadius="4"
                                Background="#6366F1" Tapped="ColorSwatch_Tapped" Tag="#6366F1" />
                        <Border x:Name="Color7" Width="22" Height="22" CornerRadius="4"
                                Background="#8B5CF6" Tapped="ColorSwatch_Tapped" Tag="#8B5CF6" />
                        <Border x:Name="Color8" Width="22" Height="22" CornerRadius="4"
                                Background="#EC4899" Tapped="ColorSwatch_Tapped" Tag="#EC4899" />
                    </StackPanel>
                </Border>

                <!-- Brush Size -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Size" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="BrushSizeSlider" Width="80"
                                Minimum="1" Maximum="20" Value="3"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="BrushSizeLabel" Text="3" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" MinWidth="16" />
                    </StackPanel>
                </Border>

                <!-- Undo/Redo -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="UndoBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="UndoBtn_Click" ToolTipService.ToolTip="Undo (Ctrl+Z)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A7;" FontSize="16" />
                        </Button>
                        <Button x:Name="RedoBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="RedoBtn_Click" ToolTipService.ToolTip="Redo (Ctrl+Y)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A6;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="ClearBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ClearBtn_Click" ToolTipService.ToolTip="Clear Canvas">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="16" />
                        </Button>
                        <Button x:Name="SaveBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="SaveBtn_Click" ToolTipService.ToolTip="Save as PNG">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Window / Presentation controls -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <!-- Pop-out to separate window -->
                        <Button x:Name="PopOutBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="PopOutBtn_Click"
                                ToolTipService.ToolTip="Open in separate window (for multi-monitor)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="15" />
                        </Button>
                        <!-- Fullscreen presentation -->
                        <Button x:Name="FullscreenBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="FullscreenBtn_Click"
                                ToolTipService.ToolTip="Fullscreen presentation (F11)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE740;" FontSize="15" />
                        </Button>
                        <!-- Vertical / 9:16 preview overlay -->
                        <Button x:Name="AspectRatioBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="AspectRatioBtn_Click"
                                ToolTipService.ToolTip="Toggle 9:16 vertical crop overlay (TikTok / Shorts)">
                            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="9:16" FontSize="9" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Monitor-level Zoom + Annotation + Quick Capture -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">

                        <!-- Screen magnifier zoom in (one ZoomSpeed step) -->
                        <Button x:Name="ScreenZoomInBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ScreenZoomInBtn_Click"
                                ToolTipService.ToolTip="Screen Zoom In (one speed step)">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" FontSize="13" />
                                <TextBlock Text="SCR" FontSize="8" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Screen magnifier zoom out -->
                        <Button x:Name="ScreenZoomOutBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ScreenZoomOutBtn_Click"
                                ToolTipService.ToolTip="Screen Zoom Out (one speed step)">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71F;" FontSize="13" />
                                <TextBlock Text="SCR" FontSize="8" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Toggle screen magnifier on/off -->
                        <Button x:Name="ScreenZoomToggleBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="ScreenZoomToggleBtn_Click"
                                ToolTipService.ToolTip="Toggle monitor-level zoom (always click-through)">
                            <FontIcon x:Name="ScreenZoomIcon" FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE8B6;" FontSize="15" />
                        </Button>

                        <!-- Zoom settings flyout (magnification + speed sliders) -->
                        <Button x:Name="ZoomSettingsBtn"
                                Style="{StaticResource WbToolButtonStyle}"
                                ToolTipService.ToolTip="Zoom settings — magnification level and speed">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <StackPanel Spacing="14" Width="250" Padding="4">

                                        <TextBlock Text="SCREEN MAGNIFIER SETTINGS"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   CharacterSpacing="80"
                                                   Foreground="{StaticResource TextTertiaryBrush}" />

                                        <!-- Magnification level -->
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="Magnification"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock x:Name="ZoomFactorLabel"
                                                           Text="2.0×"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{StaticResource BrandPrimaryBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <Slider x:Name="ZoomFactorSlider"
                                                    Minimum="1.25" Maximum="8"
                                                    StepFrequency="0.25" Value="2"
                                                    ValueChanged="ZoomFactorSlider_ValueChanged" />
                                        </StackPanel>

                                        <!-- Zoom speed per click -->
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <TextBlock Text="Speed per click"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock x:Name="ZoomSpeedLabel"
                                                           Text="0.25"
                                                           FontSize="12" FontWeight="Medium"
                                                           Foreground="{StaticResource BrandPrimaryBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <Slider x:Name="ZoomSpeedSlider"
                                                    Minimum="0.05" Maximum="1.5"
                                                    StepFrequency="0.05" Value="0.25"
                                                    ValueChanged="ZoomSpeedSlider_ValueChanged" />
                                        </StackPanel>

                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="14" />
                        </Button>

                        <!-- Screen Annotate toggle -->
                        <Button x:Name="AnnotateToggleBtn"
                                Style="{StaticResource WbToolButtonStyle}"
                                Click="AnnotateToggle_Click"
                                ToolTipService.ToolTip="Screen annotations — draw arrows, circles and freehand on top of all windows">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon x:Name="AnnotateToggleIcon"
                                          FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xECAA;" FontSize="14" />
                                <TextBlock x:Name="AnnotateToggleText"
                                           Text="Annotate" FontSize="10"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Quick screen capture → draw on whiteboard -->
                        <Button x:Name="QuickCaptureBtn" Style="{StaticResource WbToolButtonStyle}"
                                Click="QuickCaptureBtn_Click"
                                ToolTipService.ToolTip="Quick Capture — snapshot to whiteboard background">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE722;" FontSize="15" />
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Participants -->
                <Border Margin="4,0,0,0">
                    <Button Style="{StaticResource WbToolButtonStyle}"
                            Width="Auto" Padding="8,0"
                            Click="ParticipantsBtn_Click"
                            ToolTipService.ToolTip="Participants">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE716;" FontSize="14" />
                            <TextBlock x:Name="ParticipantCountText" Text="2" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1 · Screen Annotation Bar  (hidden until annotation starts)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                x:Name="AnnotationBar"
                Background="#EE0D1117"
                BorderBrush="#55636bf1"
                BorderThickness="0,1,0,1"
                Padding="10,5"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                <!-- Label -->
                <TextBlock Text="SCREEN ANNOTATIONS"
                           FontSize="9" FontWeight="SemiBold" CharacterSpacing="80"
                           Foreground="#886366F1" VerticalAlignment="Center" />

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Draw / Passthrough toggle -->
                <Button x:Name="AnnotateDrawModeBtn"
                        Style="{StaticResource WbToolButtonStyle}"
                        Click="AnnotateDrawMode_Click"
                        ToolTipService.ToolTip="Toggle Draw mode / Passthrough (click-through)">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <FontIcon x:Name="AnnotateDrawModeIcon"
                                  FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xED63;" FontSize="13" />
                        <TextBlock x:Name="AnnotateDrawModeText"
                                   Text="Drawing" FontSize="10"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Tools -->
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="AnnotatePenBtn"
                            Style="{StaticResource WbToolButtonStyle}"
                            Click="AnnotateTool_Click" Tag="0"
                            ToolTipService.ToolTip="Freehand pen">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xED63;" FontSize="13" />
                    </Button>
                    <Button x:Name="AnnotateArrowBtn"
                            Style="{StaticResource WbToolButtonStyle}"
                            Click="AnnotateTool_Click" Tag="1"
                            ToolTipService.ToolTip="Arrow — point of interest">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF090;" FontSize="13" />
                    </Button>
                    <Button x:Name="AnnotateCircleBtn"
                            Style="{StaticResource WbToolButtonStyle}"
                            Click="AnnotateTool_Click" Tag="2"
                            ToolTipService.ToolTip="Circle — highlight area">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF137;" FontSize="13" />
                    </Button>
                </StackPanel>

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Annotation colours -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Border x:Name="AnnColorRed"    Width="18" Height="18" CornerRadius="9"
                            Background="#FFFF2020" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Tapped="AnnotateColor_Tapped" Tag="#FF2020"
                            ToolTipService.ToolTip="Red" />
                    <Border x:Name="AnnColorYellow" Width="18" Height="18" CornerRadius="9"
                            Background="#FFFFD700" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Tapped="AnnotateColor_Tapped" Tag="#FFD700"
                            ToolTipService.ToolTip="Yellow" />
                    <Border x:Name="AnnColorGreen"  Width="18" Height="18" CornerRadius="9"
                            Background="#FF00E676" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Tapped="AnnotateColor_Tapped" Tag="#00E676"
                            ToolTipService.ToolTip="Green" />
                    <Border x:Name="AnnColorCyan"   Width="18" Height="18" CornerRadius="9"
                            Background="#FF00E5FF" BorderBrush="#33FFFFFF" BorderThickness="1"
                            Tapped="AnnotateColor_Tapped" Tag="#00E5FF"
                            ToolTipService.ToolTip="Cyan" />
                    <Border x:Name="AnnColorWhite"  Width="18" Height="18" CornerRadius="9"
                            Background="#FFFFFFFF" BorderBrush="#44000000" BorderThickness="1"
                            Tapped="AnnotateColor_Tapped" Tag="#FFFFFF"
                            ToolTipService.ToolTip="White" />
                </StackPanel>

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Stroke width -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Width" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center" />
                    <Slider x:Name="AnnotateWidthSlider"
                            Minimum="2" Maximum="16" Value="3" Width="80"
                            VerticalAlignment="Center"
                            ValueChanged="AnnotateWidth_Changed" />
                    <TextBlock x:Name="AnnotateWidthLabel" Text="3"
                               FontSize="10" MinWidth="18"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Undo / Clear -->
                <Button Style="{StaticResource WbToolButtonStyle}"
                        Click="AnnotateUndo_Click"
                        ToolTipService.ToolTip="Undo last stroke">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A7;" FontSize="13" />
                </Button>
                <Button Style="{StaticResource WbToolButtonStyle}"
                        Click="AnnotateClear_Click"
                        ToolTipService.ToolTip="Clear all annotations">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="13" />
                </Button>

                <Rectangle Width="1" Height="18" Fill="#22FFFFFF" />

                <!-- Stop annotation -->
                <Button Style="{StaticResource WbToolButtonStyle}"
                        Click="AnnotateStop_Click"
                        ToolTipService.ToolTip="Stop screen annotation">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="12" />
                        <TextBlock Text="Stop" FontSize="10" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2 · Canvas Area  (zoom + pan container)
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              x:Name="CanvasAreaOuter"
              Background="{StaticResource BgBaseBrush}"
              PointerWheelChanged="CanvasArea_PointerWheelChanged"
              PointerPressed="CanvasArea_PointerPressed"
              PointerMoved="CanvasArea_PointerMoved"
              PointerReleased="CanvasArea_PointerReleased"
              SizeChanged="CanvasAreaOuter_SizeChanged">

            <!-- ── Transform wrapper — scale + pan applied in code ── -->
            <Grid x:Name="CanvasWrapper"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top">
                <!-- Large virtual canvas for drawing -->
                <Canvas x:Name="WhiteboardCanvas"
                        Width="4000" Height="3000"
                        Background="{StaticResource BgBaseBrush}" />
                <!-- Non-hit-testable overlay for in-progress shape preview -->
                <Canvas x:Name="OverlayCanvas"
                        Width="4000" Height="3000"
                        IsHitTestVisible="False" />
            </Grid>

            <!-- ── Participants panel (overlay, not transformed) ── -->
            <Border x:Name="ParticipantsPanel"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="16" Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="12"
                    MinWidth="160" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="PARTICIPANTS" Style="{StaticResource SectionTitleStyle}" />
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                    Background="#6366F1" Margin="0,0,8,0">
                                <TextBlock Text="Y" Foreground="White" FontWeight="Bold"
                                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="You" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                            <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#22C55E" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                    Background="#EF4444" Margin="0,0,8,0">
                                <TextBlock Text="A" Foreground="White" FontWeight="Bold"
                                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Alex M." VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                            <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#22C55E" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── 9:16 Vertical crop overlay (TikTok / Shorts) ── -->
            <Grid x:Name="VerticalCropOverlay"
                  IsHitTestVisible="False"
                  Visibility="Collapsed">
                <!-- Left dark band -->
                <Rectangle x:Name="CropBandLeft"
                            HorizontalAlignment="Left"
                            Fill="#BB000000" />
                <!-- Right dark band -->
                <Rectangle x:Name="CropBandRight"
                            HorizontalAlignment="Right"
                            Fill="#BB000000" />
                <!-- 9:16 crop frame border (indigo) -->
                <Border x:Name="CropFrame"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        BorderBrush="#FF6366F1"
                        BorderThickness="2" />
                <!-- Label badge -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="12,12"
                        Padding="8,3"
                        Background="#CC000000" CornerRadius="6"
                        BorderBrush="#556366F1" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="9:16" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF6366F1" VerticalAlignment="Center" />
                        <TextBlock Text="Vertical · TikTok / Shorts" FontSize="10"
                                   Foreground="#AAFFFFFF" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Zoom controls (bottom-centre, not transformed) ── -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="20" Padding="4,2">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Style="{StaticResource WbToolButtonStyle}"
                            Width="28" Height="28" Click="ZoomOutBtn_Click"
                            ToolTipService.ToolTip="Zoom Out (Ctrl+−)">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71F;" FontSize="13" />
                    </Button>
                    <TextBlock x:Name="ZoomLevelText" Text="100%"
                               VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               MinWidth="44" TextAlignment="Center" />
                    <Button Style="{StaticResource WbToolButtonStyle}"
                            Width="28" Height="28" Click="ZoomInBtn_Click"
                            ToolTipService.ToolTip="Zoom In (Ctrl+=)">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource WbToolButtonStyle}"
                            Width="28" Height="28" Click="ZoomResetBtn_Click"
                            ToolTipService.ToolTip="Reset zoom (Ctrl+0)">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="11" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
