<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.RecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:RecordIt.Converters"
    xmlns:media="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{StaticResource BgBaseBrush}"
    FontSize="12">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Menu bar -->
            <RowDefinition Height="*"    />  <!-- Preview -->
            <RowDefinition Height="Auto" />  <!-- Timeline -->
            <RowDefinition Height="Auto" />  <!-- Effects -->
            <RowDefinition Height="220"  />  <!-- Docks (panels) -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 0 · Menu Bar (OBS-style)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,0,0,1">
            <MenuBar>

                <!-- File -->
                <MenuBarItem Title="File">
                    <MenuFlyoutItem x:Name="MenuStartRecord" Text="Start Recording"        Click="StartRecordBtn_Click" />
                    <MenuFlyoutItem x:Name="MenuStopRecord"  Text="Stop Recording"         Click="StopRecordBtn_Click"  IsEnabled="False" />
                    <MenuFlyoutItem x:Name="MenuStartStream" Text="Start Streaming"        Click="StartStreamBtn_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuExport"      Text="Show in Library"        Click="MenuExport_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuSettings"    Text="Settings…"              Click="MenuSettings_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuExit"        Text="Exit"                   Click="MenuExit_Click" />
                </MenuBarItem>

                <!-- Edit -->
                <MenuBarItem Title="Edit">
                    <MenuFlyoutItem x:Name="MenuAddScene"  Text="Add Scene"   Click="AddSceneBtn_Click" />
                    <MenuFlyoutItem x:Name="MenuAddSource" Text="Add Source…" Click="AddSourceBtn_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Undo"  IsEnabled="False" />
                    <MenuFlyoutItem Text="Redo"  IsEnabled="False" />
                </MenuBarItem>

                <!-- View -->
                <MenuBarItem Title="View">
                    <MenuFlyoutItem x:Name="MenuFullscreen" Text="Fullscreen Preview" Click="MenuFullscreen_Click" />
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:Name="MenuShowScenes"      Text="Scenes"             IsChecked="True"  Click="MenuTogglePanel_Click" Tag="scenes" />
                    <ToggleMenuFlyoutItem x:Name="MenuShowSources"     Text="Sources"            IsChecked="True"  Click="MenuTogglePanel_Click" Tag="sources" />
                    <ToggleMenuFlyoutItem x:Name="MenuShowMixer"       Text="Audio Mixer"        IsChecked="True"  Click="MenuTogglePanel_Click" Tag="mixer" />
                    <ToggleMenuFlyoutItem x:Name="MenuShowTransitions"  Text="Scene Transitions"  IsChecked="True"  Click="MenuTogglePanel_Click" Tag="transitions" />
                    <ToggleMenuFlyoutItem x:Name="MenuShowControls"    Text="Controls"           IsChecked="True"  Click="MenuTogglePanel_Click" Tag="controls" />
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:Name="MenuShowStatusBar"   Text="Status Bar"         IsChecked="True"  Click="MenuToggleStatusBar_Click" />
                </MenuBarItem>

                <!-- Scene Collection -->
                <MenuBarItem Title="Scene Collection">
                    <MenuFlyoutItem x:Name="MenuNewScene"       Text="New"                        Click="MenuNewScene_Click" />
                    <MenuFlyoutItem x:Name="MenuOpenScene"      Text="Open…"                      Click="MenuOpenScene_Click" />
                    <MenuFlyoutItem x:Name="MenuDuplicateScene" Text="Duplicate Current"           Click="MenuDuplicateScene_Click" />
                    <MenuFlyoutItem x:Name="MenuRenameScene"    Text="Rename…"                    Click="MenuRenameScene_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuExportScene"    Text="Export…"                    Click="MenuExportScene_Click" />
                    <MenuFlyoutItem x:Name="MenuImportScene"    Text="Import…"                    Click="MenuImportScene_Click" />
                    <MenuFlyoutSeparator />
                    <!-- Templates sub-menu -->
                    <MenuFlyoutSubItem Text="Apply Template">
                        <MenuFlyoutItem Text="Gaming / Game Capture"        Click="MenuApplyTemplate_Click" Tag="gaming" />
                        <MenuFlyoutItem Text="Just Chatting"                Click="MenuApplyTemplate_Click" Tag="chatting" />
                        <MenuFlyoutItem Text="Screen Share / Presentation"  Click="MenuApplyTemplate_Click" Tag="screenshare" />
                        <MenuFlyoutItem Text="Webcam Only"                  Click="MenuApplyTemplate_Click" Tag="webcam" />
                        <MenuFlyoutItem Text="IRL / Mobile"                 Click="MenuApplyTemplate_Click" Tag="irl" />
                        <MenuFlyoutItem Text="Podcast / Interview"          Click="MenuApplyTemplate_Click" Tag="podcast" />
                    </MenuFlyoutSubItem>
                </MenuBarItem>

                <!-- Profile -->
                <MenuBarItem Title="Profile">
                    <MenuFlyoutItem x:Name="MenuNewProfile"       Text="New Profile"        Click="MenuNewProfile_Click" />
                    <MenuFlyoutItem x:Name="MenuDuplicateProfile" Text="Duplicate Profile"  Click="MenuDuplicateProfile_Click" />
                    <MenuFlyoutItem x:Name="MenuRenameProfile"    Text="Rename Profile…"    Click="MenuRenameProfile_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuExportProfile"    Text="Export Profile…"    Click="MenuExportProfile_Click" />
                    <MenuFlyoutItem x:Name="MenuImportProfile"    Text="Import Profile…"    Click="MenuImportProfile_Click" />
                </MenuBarItem>

                <!-- Docks -->
                <MenuBarItem Title="Docks">
                    <ToggleMenuFlyoutItem x:Name="MenuLockDocksItem" Text="Lock Docks" Click="MenuLockDocks_Click" />
                    <MenuFlyoutItem Text="Reset Dock Layout"   Click="MenuResetLayout_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Float Scenes Panel"       Click="MenuFloatPanel_Click" Tag="scenes" />
                    <MenuFlyoutItem Text="Float Sources Panel"      Click="MenuFloatPanel_Click" Tag="sources" />
                    <MenuFlyoutItem Text="Float Audio Mixer"        Click="MenuFloatPanel_Click" Tag="mixer" />
                    <MenuFlyoutItem Text="Float Scene Transitions"  Click="MenuFloatPanel_Click" Tag="transitions" />
                    <MenuFlyoutItem Text="Float Controls"           Click="MenuFloatPanel_Click" Tag="controls" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Refresh Sources"     Click="RefreshSourcesBtn_Click" />
                    <MenuFlyoutItem Text="Probe Audio Devices" Click="ProbeDevicesBtn_Click" />
                </MenuBarItem>

                <!-- Tools -->
                <MenuBarItem Title="Tools">
                    <MenuFlyoutItem x:Name="MenuWhiteboard"   Text="Whiteboard"    Click="MenuWhiteboard_Click" />
                    <MenuFlyoutItem x:Name="MenuLibrary"      Text="Library"       Click="MenuLibrary_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="MenuStartPreview" Text="Start Preview" Click="StartPreviewBtn_Click" />
                    <MenuFlyoutItem x:Name="MenuStopPreview"  Text="Stop Preview"  Click="StopPreviewBtn_Click" />
                </MenuBarItem>

                <!-- Help -->
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem Text="About RecordIt" Click="MenuAbout_Click" />
                </MenuBarItem>

            </MenuBar>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1 · Preview Area
             Normal mode  : [PREVIEW *] | [Live side 360px]
             Studio mode  : [PREVIEW *] | [4px] | [PROGRAM *]
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="PreviewAreaGrid" Grid.Row="1" Background="#080808">
            <Grid.ColumnDefinitions>
                <!-- col 0: PREVIEW / main canvas -->
                <ColumnDefinition x:Name="PreviewMainCol" Width="*" />
                <!-- col 1: studio divider (0 in normal mode) -->
                <ColumnDefinition x:Name="StudioDivCol" Width="0" />
                <!-- col 2: PROGRAM panel (0 in normal mode) -->
                <ColumnDefinition x:Name="ProgramCol" Width="0" />
                <!-- col 3: small live-preview side panel (360 in normal mode) -->
                <ColumnDefinition x:Name="LiveSideCol" Width="360" />
            </Grid.ColumnDefinitions>

            <!-- ── col 0: Main PREVIEW canvas ─────────────────────────── -->
            <Border x:Name="PreviewHost"
                    Grid.Column="0"
                    Background="#000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- Screen-capture live feed (WGC frames → SoftwareBitmapSource) -->
                    <Image x:Name="PreviewScreenImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Visibility="Collapsed" />

                    <!-- Webcam / video-device live feed -->
                    <media:MediaPlayerElement x:Name="PreviewVideoElement"
                                              AreTransportControlsEnabled="False"
                                              AutoPlay="False"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Visibility="Collapsed" />

                    <!-- Hint shown when no source is active -->
                    <StackPanel x:Name="PreviewHintPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;"
                                  FontSize="40" Foreground="#22FFFFFF"
                                  HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewHintText"
                                   Text="No source selected"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#33FFFFFF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── col 1: Studio divider line ────────────────────────── -->
            <Rectangle x:Name="StudioDividerRect"
                       Grid.Column="1"
                       Fill="#222222"
                       Visibility="Collapsed" />

            <!-- ── col 2: PROGRAM panel (Studio Mode only) ────────────── -->
            <Border x:Name="ProgramHost"
                    Grid.Column="2"
                    Background="#050505"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Visibility="Collapsed">
                <Grid>
                    <!-- placeholder / live output info -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE9D5;"
                                  FontSize="40" Foreground="#22FF4444"
                                  HorizontalAlignment="Center" />
                        <TextBlock x:Name="ProgramHintText"
                                   Text="No program output"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#33FFFFFF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Webcam live preview in PROGRAM pane -->
                    <media:MediaPlayerElement x:Name="ProgramCamElement"
                                              AreTransportControlsEnabled="False"
                                              AutoPlay="False"
                                              Stretch="UniformToFill"
                                              Visibility="Collapsed" />

                    <!-- PROGRAM label overlay -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="12,10" Padding="10,4"
                            Background="#CC1A0000"
                            CornerRadius="6"
                            BorderBrush="#55EF4444" BorderThickness="1">
                        <TextBlock Text="PROGRAM"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#CCEF4444"
                                   CharacterSpacing="80" />
                    </Border>

                    <!-- Transition button (centre-top of program pane) -->
                    <Button x:Name="TransitionBtn"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,10,12,0"
                            Style="{StaticResource AlvoniaRecordButtonStyle}"
                            Click="TransitionBtn_Click"
                            ToolTipService.ToolTip="Cut — push Preview to Program">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8AB;" FontSize="11" />
                            <TextBlock Text="CUT" VerticalAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── col 3: Small Live Preview panel (normal mode) ──────── -->
                <!-- Drag splitter placed at the left edge of the live side panel -->
                    <Border Grid.Column="3" x:Name="PreviewLiveSplitter"
                        Width="8" HorizontalAlignment="Left" Background="Transparent"
                        PointerPressed="PreviewLiveSplitter_PointerPressed"
                        PointerMoved="PreviewLiveSplitter_PointerMoved"
                        PointerReleased="PreviewLiveSplitter_PointerReleased"
                        PointerEntered="PreviewLiveSplitter_PointerEntered"
                        PointerExited="PreviewLiveSplitter_PointerExited"
                        ToolTipService.ToolTip="Drag to resize preview" />

                <Border Grid.Column="3" x:Name="LivePreviewHost"
                    Background="#0A0000" BorderBrush="#151515" BorderThickness="1,0,0,0"
                    Padding="6">
                <controls:TabView>
                    <controls:TabView.Resources>
                        <Style TargetType="controls:TabViewItem">
                            <Setter Property="MinWidth" Value="68" />
                            <Setter Property="MinHeight" Value="28" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </controls:TabView.Resources>
                    <controls:TabViewItem Header="Live">
                        <Grid Padding="6">
                            <StackPanel Spacing="6">
                                <TextBlock Text="LIVE PREVIEW" FontSize="11" FontWeight="Bold" Foreground="#AAFFFFFF" />

                                <!-- Screen-capture live feed -->
                                <Image x:Name="LivePreviewScreenImage"
                                       Stretch="UniformToFill"
                                       Height="200"
                                       Visibility="Collapsed" />

                                <!-- Webcam live feed via MediaPlayer -->
                                <media:MediaPlayerElement x:Name="LivePreviewElement"
                                                          AreTransportControlsEnabled="False"
                                                          AutoPlay="False"
                                                          Stretch="UniformToFill"
                                                          Height="200"
                                                          Visibility="Collapsed" />

                                <TextBlock x:Name="LivePreviewHint"
                                           Text="No live source"
                                           FontSize="12"
                                           Foreground="#66FFFFFF" />
                            </StackPanel>
                        </Grid>
                    </controls:TabViewItem>
                    <controls:TabViewItem Header="Vertical" x:Name="VerticalTabItem">
                        <Grid Padding="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="VERTICAL PREVIEW" FontSize="11" FontWeight="Bold" Foreground="#AAFFFFFF" />
                                <Button x:Name="VerticalUndockBtn" Content="Undock" Grid.Column="1" Margin="6,0,0,0" Click="VerticalUndockBtn_Click" />
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#000" Padding="6">
                                    <Image x:Name="VerticalPreviewImage" Stretch="UniformToFill" Visibility="Visible" Height="360" Width="240" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Vertical Sources" FontWeight="SemiBold" />
                                    <ListBox x:Name="VerticalSourcesList" Height="180" SelectionChanged="VerticalSourcesList_SelectionChanged" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Add" Click="AddVerticalSourceBtn_Click" />
                                        <Button Content="Remove" Click="RemoveVerticalSourceBtn_Click" />
                                        <Button Content="Settings" Click="VerticalSourceSettingsBtn_Click" />
                                    </StackPanel>
                                    <TextBlock Text="Scenes" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <ListBox x:Name="VerticalScenesList" Height="100" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Add Scene" Click="AddVerticalSceneBtn_Click" />
                                        <Button Content="Remove Scene" Click="RemoveVerticalSceneBtn_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </controls:TabViewItem>
                </controls:TabView>
            </Border>

            <!-- ── Overlays on column 0 ───────────────────────────────── -->

            <!-- PREVIEW label top-left -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="12,10" Padding="10,4"
                    Background="#CC000000"
                    CornerRadius="6"
                    BorderBrush="#22FFFFFF" BorderThickness="1">
                <TextBlock x:Name="PreviewLabelText"
                           Text="PREVIEW"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#AAFFFFFF"
                           CharacterSpacing="80" />
            </Border>

            <!-- Small record button in preview overlay -->
            <Button x:Name="PreviewRecordBtn"
                    Grid.Column="0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="12,50,0,0"
                    Style="{StaticResource AlvoniaRecordButtonStyle}"
                    Click="StartRecordBtn_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="6" Height="6" Fill="White" VerticalAlignment="Center" />
                    <TextBlock Text="Record" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Button>

            <!-- Recording status overlay (top-right of column 0) -->
            <Border x:Name="RecordingBadge"
                    Grid.Column="0"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,12,0" Padding="10,4"
                    Background="#CC1A0000"
                    CornerRadius="6"
                    BorderBrush="#55EF4444" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#FFEF4444" />
                    <TextBlock x:Name="RecordingTimerText"
                               Text="00:00"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#FFEF4444"
                               FontFamily="Cascadia Code, Consolas" />
                </StackPanel>
            </Border>

            <!-- ── Caption overlay (above scene strip) ───────────────── -->
            <Border x:Name="CaptionOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="40,0,40,48"
                    Padding="18,8"
                    Background="#8C000000"
                    CornerRadius="8"
                    BorderBrush="#33FFFFFF" BorderThickness="1"
                    Visibility="Collapsed"
                    MaxWidth="900">
                <TextBlock x:Name="CaptionText"
                           Text=""
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ── Countdown overlay (centred, shown 3-2-1) ───────────── -->
            <Border x:Name="CountdownOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="120" Height="120"
                    Background="#CC000000"
                    CornerRadius="60"
                    BorderBrush="#44FFFFFF" BorderThickness="2"
                    Visibility="Collapsed">
                <TextBlock x:Name="CountdownText"
                           Text="3"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- ── Lower-Third / Title card overlay ──────────────── -->
            <Border x:Name="LowerThirdOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                    Margin="0,0,0,36"
                    Padding="20,10,20,12"
                    Background="#E6000000"
                    BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0"
                    Visibility="Collapsed">
                <StackPanel Spacing="2">
                    <TextBlock x:Name="LowerThirdTitle"
                               Text="Title Text"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock x:Name="LowerThirdSub"
                               Text="Subtitle / Role"
                               FontSize="13"
                               Foreground="#B3FFFFFF" />
                </StackPanel>
            </Border>

            <!-- Scene selector quick strip (bottom of preview) -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                    Background="#CC000000" Padding="12,6"
                    BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
                <ScrollViewer HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="SceneQuickBar"
                                Orientation="Horizontal" Spacing="6" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2 · Timeline View (between preview and docks)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="TimelinePanel" Grid.Row="2"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,1,0,0"
                Height="130">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Timeline toolbar -->
                <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Playback controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Go to start"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" FontSize="10" />
                            </Button>
                            <Button x:Name="TimelinePlayBtn" Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Play/Pause"
                                    Width="22" Height="22" Click="TimelinePlayBtn_Click">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Go to end"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" FontSize="10" />
                            </Button>

                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="4,0" />

                            <TextBlock x:Name="TimelinePositionText" Text="00:00.0"
                                       FontSize="11" FontWeight="Bold" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="/" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="4,0" />
                            <TextBlock x:Name="TimelineDurationText" Text="05:00.0"
                                       FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Timeline actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Add marker"
                                    Click="AddTimelineMarkerBtn_Click" Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Split at playhead"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C6;" FontSize="10" />
                            </Button>
                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Zoom out timeline"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71F;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Zoom in timeline"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" FontSize="10" />
                            </Button>
                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />
                            <Button x:Name="EffectsToggleBtn" Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Toggle effects panel"
                                    Click="EffectsToggleBtn_Click" Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" FontSize="10" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timeline tracks area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Track labels -->
                    <StackPanel Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                                BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,1,0">
                        <Border Height="18" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1" />
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Video 1" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Video 2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Audio 1" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Audio 2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <!-- Tracks + Playhead canvas -->
                    <Canvas x:Name="TimelineCanvas" Grid.Column="1" Background="Transparent">
                        <!-- Ruler and clips drawn in code-behind -->
                    </Canvas>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 3 · Effects Panel (collapsible)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="EffectsPanel" Grid.Row="3"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed"
                Height="120">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="EFFECTS" FontSize="10" FontWeight="Bold" CharacterSpacing="80"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Add effect"
                                    Click="AddEffectBtn_Click" Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Close effects"
                                    Click="EffectsToggleBtn_Click" Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="10" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Auto" Padding="6,4">
                    <StackPanel x:Name="EffectsStack" Orientation="Horizontal" Spacing="8">
                        <!-- Effect cards: Blur, Chroma Key, Color Correction, Vignette, Sharpen, etc. -->
                        <Border Background="#1A6366F1" BorderBrush="#336366F1" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Background Blur" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Gaussian blur" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A22C55E" BorderBrush="#3322C55E" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Green Screen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Chroma key removal" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="75" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AF59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Color Correct" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="White balance / tones" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AEF4444" BorderBrush="#33EF4444" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Vignette" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Dark edges cinematic" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="40" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A8B5CF6" BorderBrush="#338B5CF6" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Sharpen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Enhance edge detail" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="30" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A06B6D4" BorderBrush="#3306B6D4" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Noise Reduction" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Reduce video grain" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="60" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AFBBF24" BorderBrush="#33FBBF24" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Brightness" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Brightness / contrast" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AEC4899" BorderBrush="#33EC4899" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Saturation" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Color vibrance" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 4 · Docked Panels
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="4"
              Background="{StaticResource BgPanelBrush}"
              BorderBrush="{StaticResource BorderPanelBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ScenesColumn"    Width="175" MinWidth="100" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:Name="SourcesColumn"   Width="200" MinWidth="120" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:Name="MixerColumn"     Width="*"   MinWidth="200" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:Name="TransColumn"     Width="155" MinWidth="100" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:Name="ControlsColumn"  Width="155" MinWidth="130" />
            </Grid.ColumnDefinitions>

            <!-- ── Panel: Scenes ──────────────────────────────────────── -->
            <Grid x:Name="ScenesPanel" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SCENES" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="FloatPanel_Click" Tag="scenes"
                                ToolTipService.ToolTip="Float panel"
                                Height="18" Width="18">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="9" />
                        </Button>
                    </Grid>
                </Border>

                <ListView Grid.Row="1"
                          x:Name="ScenesList"
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource ObsListItemStyle}"
                          SelectionChanged="ScenesList_SelectionChanged"
                          Padding="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="AddSceneBtn_Click"
                                ToolTipService.ToolTip="Add Scene">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="RemoveSceneBtn_Click"
                                ToolTipService.ToolTip="Remove Scene">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="SceneUpBtn_Click"
                                ToolTipService.ToolTip="Move Up">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="SceneDownBtn_Click"
                                ToolTipService.ToolTip="Move Down">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Draggable splitter: Scenes | Sources -->
            <Border Grid.Column="1" x:Name="ScenesSourcesSplitter"
                    Width="5" HorizontalAlignment="Stretch" Background="Transparent"
                    PointerPressed="PanelSplitter_PointerPressed"
                    PointerMoved="PanelSplitter_PointerMoved"
                    PointerReleased="PanelSplitter_PointerReleased"
                    PointerEntered="PanelSplitter_PointerEntered"
                    PointerExited="PanelSplitter_PointerExited"
                    Tag="scenes-sources"
                    ToolTipService.ToolTip="Drag to resize">
                <Rectangle Width="1" HorizontalAlignment="Center"
                           Fill="{StaticResource BorderPanelBrush}" />
            </Border>

            <!-- ── Panel: Sources ─────────────────────────────────────── -->
            <Grid x:Name="SourcesPanel" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SOURCES" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="FloatPanel_Click" Tag="sources"
                                ToolTipService.ToolTip="Float panel"
                                Height="18" Width="18">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="9" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Sources list + empty-state overlay share the same cell -->
                <Grid Grid.Row="1">

                    <ListView x:Name="SourcesList"
                              Background="Transparent"
                              ItemContainerStyle="{StaticResource ObsListItemStyle}"
                              SelectionChanged="SourcesList_SelectionChanged"
                              Padding="2">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="{Binding Icon}"
                                              FontSize="11"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <!-- Visibility eye icon -->
                                    <FontIcon Grid.Column="2"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="&#xE7B3;"
                                              FontSize="10"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                    <!-- Lock icon -->
                                    <FontIcon Grid.Column="3"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="&#xE72E;"
                                              FontSize="10"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty-state overlay — visible when scene has no sources -->
                    <Border x:Name="SourcesEmptyState"
                            Visibility="Visible"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Margin="12">
                            <!-- Dashed question-mark icon -->
                            <Border Width="40" Height="40"
                                    CornerRadius="6"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1.5"
                                    HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE897;"
                                          FontSize="18"
                                          Foreground="#44FFFFFF"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="You don't have any sources."
                                       FontSize="11"
                                       Foreground="#99FFFFFF"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Click the + button below,"
                                       FontSize="10"
                                       Foreground="#AA6EA0FF"
                                       TextAlignment="Center" />
                            <TextBlock Text="or right click here to add one."
                                       FontSize="10"
                                       Foreground="#AA6EA0FF"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                </Grid>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="AddSourceBtn_Click"
                                ToolTipService.ToolTip="Add Source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="RemoveSourceBtn_Click"
                                ToolTipService.ToolTip="Remove Source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="SourceUpBtn_Click"
                                ToolTipService.ToolTip="Move Up">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="SourceDownBtn_Click"
                                ToolTipService.ToolTip="Move Down">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="SourceSettingsBtn_Click"
                                ToolTipService.ToolTip="Source Settings">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Draggable splitter: Sources | Mixer -->
            <Border Grid.Column="3" x:Name="SourcesMixerSplitter"
                    Width="5" HorizontalAlignment="Stretch" Background="Transparent"
                    PointerPressed="PanelSplitter_PointerPressed"
                    PointerMoved="PanelSplitter_PointerMoved"
                    PointerReleased="PanelSplitter_PointerReleased"
                    PointerEntered="PanelSplitter_PointerEntered"
                    PointerExited="PanelSplitter_PointerExited"
                    Tag="sources-mixer"
                    ToolTipService.ToolTip="Drag to resize">
                <Rectangle Width="1" HorizontalAlignment="Center"
                           Fill="{StaticResource BorderPanelBrush}" />
            </Border>

            <!-- ── Panel: Audio Mixer ─────────────────────────────────── -->
            <Grid x:Name="MixerPanel" Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="AUDIO MIXER"
                                   Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                            <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                    Click="ProbeDevicesBtn_Click"
                                    ToolTipService.ToolTip="Refresh audio devices"
                                    Height="18" Width="18">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="9" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                    Click="FloatPanel_Click" Tag="mixer"
                                    ToolTipService.ToolTip="Float panel"
                                    Height="18" Width="18">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="9" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Mixer channels - populated in code -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Hidden"
                              Padding="6,4">
                    <StackPanel x:Name="AudioMixerChannels"
                                Orientation="Horizontal"
                                Spacing="2" />
                </ScrollViewer>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="AddAudioTrackBtn_Click"
                                ToolTipService.ToolTip="Add audio source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="ClearAudioTracksBtn_Click"
                                ToolTipService.ToolTip="Remove all audio sources">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Draggable splitter: Mixer | Transitions -->
            <Border Grid.Column="5" x:Name="MixerTransSplitter"
                    Width="5" HorizontalAlignment="Stretch" Background="Transparent"
                    PointerPressed="PanelSplitter_PointerPressed"
                    PointerMoved="PanelSplitter_PointerMoved"
                    PointerReleased="PanelSplitter_PointerReleased"
                    PointerEntered="PanelSplitter_PointerEntered"
                    PointerExited="PanelSplitter_PointerExited"
                    Tag="mixer-trans"
                    ToolTipService.ToolTip="Drag to resize">
                <Rectangle Width="1" HorizontalAlignment="Center"
                           Fill="{StaticResource BorderPanelBrush}" />
            </Border>

            <!-- ── Panel: Scene Transitions ───────────────────────────── -->
            <Grid x:Name="TransitionsPanel" Grid.Column="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header with undock button -->
                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SCENE TRANSITIONS" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="FloatPanel_Click" Tag="transitions"
                                ToolTipService.ToolTip="Float panel"
                                Height="18" Width="18">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="9" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Transition list / quick transitions area -->
                <ScrollViewer Grid.Row="1" Padding="6,6">
                    <StackPanel Spacing="6">

                        <!-- Active transition selector -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="TRANSITION"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TransitionTypeCombo"
                                          Grid.Column="0"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          HorizontalAlignment="Stretch"
                                          FontSize="12"
                                          SelectedIndex="0"
                                          SelectionChanged="TransitionTypeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Cut" />
                                    <ComboBoxItem Content="Fade" />
                                    <ComboBoxItem Content="Swipe" />
                                    <ComboBoxItem Content="Slide" />
                                    <ComboBoxItem Content="Fade to Color" />
                                    <ComboBoxItem Content="Luma Wipe" />
                                    <ComboBoxItem Content="Stinger" />
                                </ComboBox>
                                <Button Grid.Column="1"
                                        Style="{StaticResource ObsToolbarBtnStyle}"
                                        Click="TransitionPropertiesBtn_Click"
                                        ToolTipService.ToolTip="Transition Properties"
                                        Width="26" Height="26">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Duration -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="DURATION (ms)"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TransitionDurationCombo"
                                          Grid.Column="0"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          HorizontalAlignment="Stretch"
                                          FontSize="12"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="100 ms" Tag="100" />
                                    <ComboBoxItem Content="250 ms" Tag="250" />
                                    <ComboBoxItem Content="500 ms" Tag="500" />
                                    <ComboBoxItem Content="750 ms" Tag="750" />
                                    <ComboBoxItem Content="1000 ms" Tag="1000" />
                                    <ComboBoxItem Content="1500 ms" Tag="1500" />
                                    <ComboBoxItem Content="2000 ms" Tag="2000" />
                                </ComboBox>
                                <!-- Custom duration input -->
                                <Button Grid.Column="1"
                                        Style="{StaticResource ObsToolbarBtnStyle}"
                                        Click="TransitionDurationCustomBtn_Click"
                                        ToolTipService.ToolTip="Set custom duration"
                                        Width="26" Height="26">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="11" />
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Quick Transitions divider -->
                        <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,4" />

                        <TextBlock Text="QUICK TRANSITIONS"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   CharacterSpacing="80" />

                        <!-- Quick transition buttons -->
                        <StackPanel x:Name="QuickTransitionsStack" Spacing="3">
                            <!-- Populated in code or default entries below -->
                            <Border Background="{StaticResource BgElevatedBrush}"
                                    CornerRadius="6" Padding="8,5"
                                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Cut  —  0 ms"
                                               FontSize="11"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ObsToolbarBtnStyle}"
                                            Width="20" Height="20"
                                            Click="RemoveQuickTransitionBtn_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="9" />
                                    </Button>
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource BgElevatedBrush}"
                                    CornerRadius="6" Padding="8,5"
                                    BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Fade  —  300 ms"
                                               FontSize="11"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ObsToolbarBtnStyle}"
                                            Width="20" Height="20"
                                            Click="RemoveQuickTransitionBtn_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="9" />
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Toolbar: add transition -->
                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="AddQuickTransitionBtn_Click"
                                ToolTipService.ToolTip="Add quick transition">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="TransitionPropertiesBtn_Click"
                                ToolTipService.ToolTip="Transition properties">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Draggable splitter: Transitions | Controls -->
            <Border Grid.Column="7" x:Name="TransControlsSplitter"
                    Width="5" HorizontalAlignment="Stretch" Background="Transparent"
                    PointerPressed="PanelSplitter_PointerPressed"
                    PointerMoved="PanelSplitter_PointerMoved"
                    PointerReleased="PanelSplitter_PointerReleased"
                    PointerEntered="PanelSplitter_PointerEntered"
                    PointerExited="PanelSplitter_PointerExited"
                    Tag="trans-controls"
                    ToolTipService.ToolTip="Drag to resize">
                <Rectangle Width="1" HorizontalAlignment="Center"
                           Fill="{StaticResource BorderPanelBrush}" />
            </Border>

            <!-- ── Panel: Controls ────────────────────────────────────── -->
            <Grid x:Name="ControlsPanel" Grid.Column="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header with undock button -->
                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CONTROLS" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                Click="FloatPanel_Click" Tag="controls"
                                ToolTipService.ToolTip="Float panel"
                                Height="18" Width="18">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A7;" FontSize="9" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Scrollable controls content (OBS order) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="8,8" Spacing="5">

                        <!-- ── 1. Start Streaming ─────────────────── -->
                        <Button x:Name="StartStreamBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="StartStreamBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE774;" FontSize="11" />
                                <TextBlock x:Name="StreamBtnText" Text="Start Streaming" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ── 2. Start / Stop Recording + Pause ───── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="StartRecordBtn"
                                    Grid.Column="0"
                                    Style="{StaticResource AlvoniaRecordButtonStyle}"
                                    Click="StartRecordBtn_Click">
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center" />
                                    <TextBlock x:Name="RecordBtnText" Text="Start Recording" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Pause button (only visible during recording) -->
                            <Button x:Name="PauseRecordBtn"
                                    Grid.Column="1"
                                    Style="{StaticResource ControlsPanelBtnStyle}"
                                    Click="PauseRecordBtn_Click"
                                    Visibility="Collapsed"
                                    Width="32" Padding="0" Margin="4,0,0,0"
                                    ToolTipService.ToolTip="Pause / Resume Recording">
                                <FontIcon x:Name="PauseRecordIcon"
                                          FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE769;" FontSize="11" />
                            </Button>
                        </Grid>

                        <!-- Stop Recording button -->
                        <Button x:Name="StopRecordBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="StopRecordBtn_Click"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;"
                                          FontSize="11" Foreground="{StaticResource RecordingBrush}" />
                                <TextBlock Text="Stop Recording" />
                            </StackPanel>
                        </Button>

                        <!-- ── 3. Start Virtual Camera ─────────────── -->
                        <Button x:Name="VirtualCamBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="VirtualCamBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="11" />
                                <TextBlock x:Name="VirtualCamBtnText" Text="Start Virtual Camera" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ── 4. Start Preview ───────────────────── -->
                        <Button x:Name="StartPreviewBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="StartPreviewBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="11" />
                                <TextBlock Text="Start Preview" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="StopPreviewBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="StopPreviewBtn_Click"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE769;" FontSize="11" />
                                <TextBlock Text="Stop Preview" />
                            </StackPanel>
                        </Button>

                        <!-- ── 5. Studio Mode ─────────────────────── -->
                        <Button x:Name="StudioModeBtn"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="StudioModeBtn_Click"
                                ToolTipService.ToolTip="Studio Mode: Preview left, Program right">
                            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B1;" FontSize="11" />
                                <TextBlock x:Name="StudioModeBtnText" Text="Studio Mode" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ── Divider ─────────────────────────────── -->
                        <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,2" />

                        <!-- ── CC / Auto Captions ──────────────────── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="CcBtn"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ControlsPanelBtnStyle}"
                                    Click="CcBtn_Click"
                                    ToolTipService.ToolTip="Toggle live auto-captions (CC)">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7F0;" FontSize="11" />
                                    <TextBlock x:Name="CcBtnText" Text="Auto Captions" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource ObsToolbarBtnStyle}"
                                    Click="CcSettingsBtn_Click"
                                    ToolTipService.ToolTip="Caption Settings"
                                    Width="28" Height="28" Margin="4,0,0,0">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                            </Button>
                        </Grid>

                        <!-- ── Save Clip (Replay Buffer) ──────────── -->
                        <Button x:Name="SaveClipBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="SaveClipBtn_Click"
                                IsEnabled="False"
                                ToolTipService.ToolTip="Save the last 30 seconds as a clip">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="11" />
                                <TextBlock Text="Save Clip (30s)" />
                            </StackPanel>
                        </Button>

                        <!-- ── Lower Third ────────────────────────── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="LowerThirdBtn"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ControlsPanelBtnStyle}"
                                    Click="LowerThirdBtn_Click"
                                    ToolTipService.ToolTip="Show/hide lower-third title card overlay">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D2;" FontSize="11" />
                                    <TextBlock x:Name="LowerThirdBtnText" Text="Lower Third" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Style="{StaticResource ControlsPanelBtnStyle}"
                                    Width="32" Padding="0"
                                    Click="LowerThirdSettingsBtn_Click"
                                    ToolTipService.ToolTip="Configure lower-third text">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                            </Button>
                        </Grid>

                        <!-- ── Recording options ──────────────────── -->
                        <Border Background="#0AFFFFFF" CornerRadius="6" Padding="8,7"
                                BorderBrush="#1AFFFFFF" BorderThickness="1">
                            <StackPanel Spacing="5">
                                <CheckBox x:Name="CountdownCheckBox"
                                          Content="3-2-1 countdown"
                                          FontSize="12" IsChecked="True" />
                                <CheckBox x:Name="NoiseSuppCheckBox"
                                          Content="Noise suppression"
                                          FontSize="12" IsChecked="False" />
                            </StackPanel>
                        </Border>

                        <!-- ── Quick Settings (Resolution / FPS / Camera / Mic) ── -->
                        <Border Background="#0AFFFFFF" CornerRadius="6" Padding="8,7"
                                BorderBrush="#1AFFFFFF" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="QUICK SETTINGS"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           CharacterSpacing="80" />
                                <!-- Resolution -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Resolution" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <ComboBox x:Name="QualityCombo"
                                              Style="{StaticResource AlvoniaComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="11" SelectedIndex="0">
                                        <ComboBoxItem Content="1080p (1920×1080)" />
                                        <ComboBoxItem Content="1440p (2560×1440)" />
                                        <ComboBoxItem Content="4K (3840×2160)" />
                                        <ComboBoxItem Content="720p (1280×720)" />
                                        <ComboBoxItem Content="480p (854×480)" />
                                    </ComboBox>
                                </StackPanel>
                                <!-- Frame Rate -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Frame Rate" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <ComboBox x:Name="FpsCombo"
                                              Style="{StaticResource AlvoniaComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="11" SelectedIndex="1">
                                        <ComboBoxItem Content="60 fps" />
                                        <ComboBoxItem Content="30 fps" />
                                        <ComboBoxItem Content="24 fps" />
                                        <ComboBoxItem Content="15 fps" />
                                    </ComboBox>
                                </StackPanel>
                                <!-- Camera -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Camera Overlay" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <ComboBox x:Name="WebcamDeviceCombo"
                                              Style="{StaticResource AlvoniaComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="11">
                                        <ComboBoxItem Content="(disabled)" IsSelected="True" />
                                    </ComboBox>
                                </StackPanel>
                                <!-- Mic -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Mic / Audio Input" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <ComboBox x:Name="MicDeviceCombo"
                                              Style="{StaticResource AlvoniaComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              FontSize="11">
                                        <ComboBoxItem Content="Default Microphone" IsSelected="True" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Separate MP3 audio track -->
                        <Border Background="#0AFFFFFF"
                                CornerRadius="6" Padding="8,7"
                                BorderBrush="#1AFFFFFF" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <CheckBox x:Name="SepAudioCheckBox"
                                          Content="Save separate audio (MP3)"
                                          FontSize="12"
                                          IsChecked="False" />
                                <StackPanel x:Name="SepAudioOptions"
                                            Orientation="Horizontal" Spacing="8"
                                            Visibility="{x:Bind SepAudioCheckBox.IsChecked,
                                                Converter={StaticResource BoolToVisibilityConverter},
                                                Mode=OneWay}">
                                    <TextBlock Text="Bitrate" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <ComboBox x:Name="Mp3BitrateCombo"
                                              FontSize="11" Height="28"
                                              SelectedIndex="1">
                                        <ComboBoxItem Content="128 kbps" Tag="128" />
                                        <ComboBoxItem Content="192 kbps" Tag="192" />
                                        <ComboBoxItem Content="256 kbps" Tag="256" />
                                        <ComboBoxItem Content="320 kbps — max quality" Tag="320" />
                                        <ComboBoxItem Content="All bitrates (128/192/256/320)" Tag="all" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Divider ─────────────────────────────── -->
                        <Border Height="1" Background="{StaticResource BorderDefaultBrush}" Margin="0,2" />

                        <!-- ── 6. Settings ────────────────────────── -->
                        <Button Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="MenuSettings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                                <TextBlock Text="Settings" />
                            </StackPanel>
                        </Button>

                        <!-- ── 7. Open Library ────────────────────── -->
                        <Button x:Name="ExportBtn"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Click="ExportBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="11" />
                                <TextBlock Text="Open Library" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── Status bar at bottom of Controls ──────────────── -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgBaseBrush}"
                        BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,1,0,0"
                        Padding="8,5">
                    <StackPanel Spacing="2">
                        <!-- Recording status row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="REC " FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource RecordingBrush}" />
                            <TextBlock x:Name="RecStatusText" Grid.Column="1"
                                       Text="00:00:00" FontSize="10"
                                       FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                        </Grid>
                        <!-- Stream status row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="STR " FontSize="10" FontWeight="SemiBold"
                                       Foreground="#FF22C55E" />
                            <TextBlock x:Name="StreamStatusText" Grid.Column="1"
                                       Text="00:00:00" FontSize="10"
                                       FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                        </Grid>
                        <!-- General status text -->
                        <TextBlock x:Name="StatusText"
                                   Text="Ready"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Floating Recording Toolbar (overlay, visible during recording)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:Name="FloatingToolbar"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,60,0,0"
                Background="#F00D0D0D"
                CornerRadius="12"
                BorderBrush="#336366F1" BorderThickness="1"
                Padding="6,4"
                Visibility="Collapsed"
                ManipulationMode="TranslateX,TranslateY"
                ManipulationDelta="FloatingToolbar_ManipulationDelta">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- Drag handle -->
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE784;" FontSize="12"
                          Foreground="#66FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0" />

                <!-- Stop button -->
                <Button x:Name="FloatingStopBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="StopRecordBtn_Click" ToolTipService.ToolTip="Stop Recording"
                        Background="#26EF4444" Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;" FontSize="12" Foreground="#FFEF4444" />
                </Button>

                <!-- Timer -->
                <Border Padding="6,0" Background="#1AEF4444" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#FFEF4444" VerticalAlignment="Center" />
                        <TextBlock x:Name="FloatingTimerText" Text="00:00"
                                   FontSize="12" FontWeight="Bold" FontFamily="Cascadia Code, Consolas"
                                   Foreground="#FFEF4444" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Width="1" Height="20" Background="#333333" Margin="2,0" />

                <!-- Mic toggle -->
                <Button x:Name="FloatingMicBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="FloatingMicBtn_Click" ToolTipService.ToolTip="Toggle Microphone"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="12" />
                </Button>

                <!-- Camera toggle -->
                <Button x:Name="FloatingCamBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="FloatingCamBtn_Click" ToolTipService.ToolTip="Toggle Camera"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="12" />
                </Button>

                <Border Width="1" Height="20" Background="#333333" Margin="2,0" />

                <!-- Screen annotation / drawing -->
                <Button x:Name="FloatingDrawBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="FloatingDrawBtn_Click" ToolTipService.ToolTip="Screen Annotation"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="12" />
                </Button>

                <!-- Zoom -->
                <Button x:Name="FloatingZoomBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="FloatingZoomBtn_Click" ToolTipService.ToolTip="Zoom"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71E;" FontSize="12" />
                </Button>

                <!-- Minimize toolbar -->
                <Button x:Name="FloatingMinBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                        Click="FloatingMinBtn_Click" ToolTipService.ToolTip="Minimize Toolbar"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE921;" FontSize="12" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
