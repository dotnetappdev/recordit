<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="24,20"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Library" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock x:Name="LibrarySubtitle"
                               Text="6 recordings · 496 MB used"
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource AlvoniaGhostButtonStyle}"
                        Click="FilterBtn_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71C;" FontSize="13" />
                        <TextBlock Text="Filter" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="20">

                <!-- Stats -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEA69;" FontSize="18"
                                      Foreground="{StaticResource BrandPrimaryBrush}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="3" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Videos" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB9F;" FontSize="18"
                                      Foreground="{StaticResource BrandSecondaryBrush}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="3" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Whiteboards" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEDA2;" FontSize="18"
                                      Foreground="{StaticResource BrandAccentBrush}" VerticalAlignment="Center" />
                            <StackPanel>
                                <TextBlock Text="496 MB" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Storage Used" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Search + Filter -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="SearchBox"
                             PlaceholderText="Search recordings..."
                             Background="{StaticResource BgElevatedBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CornerRadius="8" />
                    <Button Grid.Column="1" x:Name="AllFilterBtn"
                            Style="{StaticResource AlvoniaPrimaryButtonStyle}"
                            Click="AllFilter_Click">
                        <TextBlock Text="All" />
                    </Button>
                    <Button Grid.Column="2" x:Name="VideoFilterBtn"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                            Click="VideoFilter_Click">
                        <TextBlock Text="Videos" />
                    </Button>
                    <Button Grid.Column="3" x:Name="WhiteboardFilterBtn"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                            Click="WhiteboardFilter_Click">
                        <TextBlock Text="Whiteboards" />
                    </Button>
                </Grid>

                <!-- Recordings Grid -->
                <GridView x:Name="RecordingsGrid"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="RecordingItem_Click">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260"
                                    CornerRadius="12"
                                    Background="{StaticResource BgSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="4">
                                <StackPanel>
                                    <Border Height="146" CornerRadius="12,12,0,0"
                                            Background="{StaticResource BgOverlayBrush}">
                                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                                  Glyph="{Binding TypeIcon}"
                                                  FontSize="32"
                                                  Foreground="{StaticResource TextTertiaryBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Padding="12,10">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Date}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="·" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" />
                                            <TextBlock Text="{Binding Size}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
