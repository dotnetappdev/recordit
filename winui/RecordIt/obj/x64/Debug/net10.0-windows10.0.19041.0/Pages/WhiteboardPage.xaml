<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.WhiteboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource BgBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <!-- Drawing Tools Group -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="0,0,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='30' x:Name="SelectToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="select"
                                ToolTipService.ToolTip="Select">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B0;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='31' x:Name="PenToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="pen"
                                ToolTipService.ToolTip="Pen">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xED63;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='32' x:Name="HighlighterToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="highlighter"
                                ToolTipService.ToolTip="Highlighter">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='33' x:Name="EraserToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="eraser"
                                ToolTipService.ToolTip="Eraser">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xED60;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Shape Tools Group -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='25' x:Name="LineToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="line"
                                ToolTipService.ToolTip="Line">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF576;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='26' x:Name="RectToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="rect"
                                ToolTipService.ToolTip="Rectangle">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C7;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='27' x:Name="CircleToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="circle"
                                ToolTipService.ToolTip="Ellipse">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xF137;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='28' x:Name="TextToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="text"
                                ToolTipService.ToolTip="Text">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D2;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='29' x:Name="StickyToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      Tag="sticky"
                                ToolTipService.ToolTip="Sticky Note">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70B;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Pan tool -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <Button x:ConnectionId='24' x:Name="PanToolBtn" Style="{StaticResource WbToolButtonStyle}"
                                                  Tag="pan"
                            ToolTipService.ToolTip="Pan">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C2;" FontSize="16" />
                    </Button>
                </Border>

                <!-- Color Palette -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                        <Border x:ConnectionId='16' x:Name="Color1" Width="22" Height="22" CornerRadius="4"
                                Background="#F5F5F5" BorderBrush="#555" BorderThickness="1"
                                                            Tag="#F5F5F5" />
                        <Border x:ConnectionId='17' x:Name="Color2" Width="22" Height="22" CornerRadius="4"
                                Background="#EF4444"                             Tag="#EF4444" />
                        <Border x:ConnectionId='18' x:Name="Color3" Width="22" Height="22" CornerRadius="4"
                                Background="#F59E0B"                             Tag="#F59E0B" />
                        <Border x:ConnectionId='19' x:Name="Color4" Width="22" Height="22" CornerRadius="4"
                                Background="#22C55E"                             Tag="#22C55E" />
                        <Border x:ConnectionId='20' x:Name="Color5" Width="22" Height="22" CornerRadius="4"
                                Background="#06B6D4"                             Tag="#06B6D4" />
                        <Border x:ConnectionId='21' x:Name="Color6" Width="22" Height="22" CornerRadius="4"
                                Background="#6366F1"                             Tag="#6366F1" />
                        <Border x:ConnectionId='22' x:Name="Color7" Width="22" Height="22" CornerRadius="4"
                                Background="#8B5CF6"                             Tag="#8B5CF6" />
                        <Border x:ConnectionId='23' x:Name="Color8" Width="22" Height="22" CornerRadius="4"
                                Background="#EC4899"                             Tag="#EC4899" />
                    </StackPanel>
                </Border>

                <!-- Brush Size -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Size" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center" />
                        <Slider x:ConnectionId='14' x:Name="BrushSizeSlider" Width="80"
                                Minimum="1" Maximum="20" Value="3"
                                VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='15' x:Name="BrushSizeLabel" Text="3" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" MinWidth="16" />
                    </StackPanel>
                </Border>

                <!-- Undo/Redo -->
                <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='12' x:Name="UndoBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      ToolTipService.ToolTip="Undo (Ctrl+Z)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A7;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='13' x:Name="RedoBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      ToolTipService.ToolTip="Redo (Ctrl+Y)">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7A6;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='10' x:Name="ClearBtn" Style="{StaticResource WbToolButtonStyle}"
                                                       ToolTipService.ToolTip="Clear Canvas">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="16" />
                        </Button>
                        <Button x:ConnectionId='11' x:Name="SaveBtn" Style="{StaticResource WbToolButtonStyle}"
                                                      ToolTipService.ToolTip="Save as PNG">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Participants (right aligned) -->
                <Border Margin="4,0,0,0">
                    <Button x:ConnectionId='8' Style="{StaticResource WbToolButtonStyle}"
                            Width="Auto" Padding="8,0"
                                                         
                            ToolTipService.ToolTip="Participants">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE716;" FontSize="14" />
                            <TextBlock x:ConnectionId='9' x:Name="ParticipantCountText" Text="2" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Border>

        <!-- Canvas Area -->
        <Grid Grid.Row="1">
            <!-- Background with grid pattern -->
            <Canvas x:ConnectionId='2' x:Name="WhiteboardCanvas"
                                                          
                                                      
                                                            
                    Background="{StaticResource BgBaseBrush}" />

            <!-- Overlay for drawing feedback -->
            <Canvas x:ConnectionId='3' x:Name="OverlayCanvas"
                    IsHitTestVisible="False" />

            <!-- Participants panel (flyout) -->
            <Border x:ConnectionId='4' x:Name="ParticipantsPanel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="16"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    MinWidth="160"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="PARTICIPANTS" Style="{StaticResource SectionTitleStyle}" />
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                    Background="#6366F1" Margin="0,0,8,0">
                                <TextBlock Text="Y" Foreground="White" FontWeight="Bold"
                                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="You" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                            <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#22C55E" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                    Background="#EF4444" Margin="0,0,8,0">
                                <TextBlock Text="A" Foreground="White" FontWeight="Bold"
                                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Alex M." VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                            <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#22C55E" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                    Background="#22C55E" Margin="0,0,8,0">
                                <TextBlock Text="S" Foreground="White" FontWeight="Bold"
                                           FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Sam K." VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                            <Ellipse Grid.Column="2" Width="8" Height="8" Fill="#737373" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Zoom Controls -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="4,2">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button x:ConnectionId='5' Style="{StaticResource WbToolButtonStyle}"
                            Width="28" Height="28"                         
                            ToolTipService.ToolTip="Zoom Out">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71F;" FontSize="13" />
                    </Button>
                    <TextBlock x:ConnectionId='6' x:Name="ZoomLevelText" Text="100%"
                               VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               MinWidth="40" TextAlignment="Center" />
                    <Button x:ConnectionId='7' Style="{StaticResource WbToolButtonStyle}"
                            Width="28" Height="28"                        
                            ToolTipService.ToolTip="Zoom In">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" FontSize="13" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

