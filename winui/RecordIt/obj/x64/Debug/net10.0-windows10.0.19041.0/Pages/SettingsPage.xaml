<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="24,20"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="2">
                <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Configure RecordIt preferences"
                           Style="{StaticResource PageSubtitleStyle}" />
            </StackPanel>
        </Border>

        <!-- Settings Body -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="640">

                <!-- Appearance -->
                <StackPanel Spacing="12">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <!-- Theme -->
                            <Grid Padding="0,4" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Theme" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Choose your preferred color scheme" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ComboBox x:ConnectionId='36' x:Name="ThemeCombo" Grid.Column="1"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="Dark" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="System" />
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <!-- Language -->
                            <Grid Padding="0,16,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Language" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Interface language" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ComboBox x:ConnectionId='35' x:Name="LanguageCombo" Grid.Column="1"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="English" />
                                    <ComboBoxItem Content="Deutsch" />
                                    <ComboBoxItem Content="Français" />
                                    <ComboBoxItem Content="Español" />
                                    <ComboBoxItem Content="日本語" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Recording -->
                <StackPanel Spacing="12">
                    <TextBlock Text="RECORDING" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Spacing="0">
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Default Quality" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Output video resolution" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='34' x:Name="QualityCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="1080p HD"/>
                                    <ComboBoxItem Content="1440p QHD"/>
                                    <ComboBoxItem Content="4K Ultra HD"/>
                                    <ComboBoxItem Content="720p"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Output Format" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Container format for recordings" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='33' x:Name="FormatCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="MP4 (H.264)"/>
                                    <ComboBoxItem Content="WebM (VP9)"/>
                                    <ComboBoxItem Content="MKV"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Show Countdown" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="3-second countdown before recording" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='32' x:Name="CountdownToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Encoding -->
                <StackPanel Spacing="12">
                    <TextBlock Text="ENCODING" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Spacing="0">

                            <!-- Hardware encoding toggle -->
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Hardware Encoding" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Use GPU encoder (NVENC / AMF / QSV) instead of CPU libx264"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='31' x:Name="HardwareEncodingToggle" Grid.Column="1"
                                              IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}"
                                                                                       />
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />

                            <!-- GPU / Encoder selector -->
                            <Grid Padding="0,12" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="GPU / Encoder" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:ConnectionId='30' x:Name="EncoderStatusText"
                                               Text="Detecting encoders…"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='28' x:Name="EncoderCombo" Grid.Column="1"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          Width="280" IsEnabled="False"
                                                                                          
                                          Margin="12,0,0,0" />
                                <Button x:ConnectionId='29' x:Name="RefreshEncodersBtn" Grid.Column="2"
                                        Content="Refresh" Margin="8,0,0,0"
                                                                      />
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>

                        <!-- FFmpeg -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="FFMPEG" Style="{StaticResource SectionTitleStyle}" />
                            <Border Style="{StaticResource AlvoniaCardStyle}">
                                <StackPanel Spacing="12">
                                    <Grid Padding="0,4" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="FFmpeg Path" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="Path to ffmpeg executable (optional)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <TextBox x:ConnectionId='25' x:Name="FfmpegPathBox" Width="360"                                  />
                                            <Button x:ConnectionId='26' Content="Browse..."                            />
                                            <Button x:ConnectionId='27' x:Name="FfmpegVerifyBtn" Content="Verify"                            />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border x:ConnectionId='23' x:Name="FfmpegStatusBadge" Width="12" Height="12" CornerRadius="6" Background="{StaticResource TextSecondaryBrush}" Visibility="Collapsed" />
                                        <TextBlock x:ConnectionId='24' x:Name="FfmpegStatusText" Text="Not verified" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- System -->
                <StackPanel Spacing="12">
                    <TextBlock Text="SYSTEM" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Notifications" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Show notifications when recording completes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='22' x:Name="NotificationsToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Start Minimized" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Launch RecordIt minimized to system tray" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='21' x:Name="StartMinimizedToggle" Grid.Column="1" IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Cursor & Mouse Effects (Camtasia-inspired) -->
                <StackPanel Spacing="12">
                    <TextBlock Text="CURSOR &amp; MOUSE EFFECTS" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Capture Mouse Cursor" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Include cursor in recordings" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='20' x:Name="CaptureCursorToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Cursor Highlight" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Show a colored circle around the cursor" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='19' x:Name="CursorHighlightToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Click Animation" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Show ripple animation on mouse clicks" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='18' x:Name="ClickAnimToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Smart Focus (Auto-Zoom)" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Automatically zoom to mouse activity area" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='17' x:Name="SmartFocusToggle" Grid.Column="1" IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Auto Zoom on Click" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Zoom in briefly when clicking (Camtasia-style)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='16' x:Name="AutoZoomClickToggle" Grid.Column="1" IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Webcam Overlay -->
                <StackPanel Spacing="12">
                    <TextBlock Text="WEBCAM OVERLAY" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Webcam Shape" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Shape of the PiP webcam overlay" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='15' x:Name="WebcamShapeCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="140" SelectedIndex="1">
                                    <ComboBoxItem Content="Rectangle"/>
                                    <ComboBoxItem Content="Rounded"/>
                                    <ComboBoxItem Content="Circle"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Default Position" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Where to place webcam overlay" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='14' x:Name="WebcamPositionCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="140" SelectedIndex="0">
                                    <ComboBoxItem Content="Bottom Right"/>
                                    <ComboBoxItem Content="Bottom Left"/>
                                    <ComboBoxItem Content="Top Right"/>
                                    <ComboBoxItem Content="Top Left"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Webcam Size" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Size relative to screen" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Slider x:ConnectionId='13' x:Name="WebcamSizeSlider" Grid.Column="1" Minimum="10" Maximum="50" Value="25" Width="140" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Audio Advanced -->
                <StackPanel Spacing="12">
                    <TextBlock Text="AUDIO" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Record System Audio" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Capture desktop / application audio" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='12' x:Name="SystemAudioToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Separate Audio Tracks" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Record mic and system audio as separate tracks" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='11' x:Name="SeparateTracksToggle" Grid.Column="1" IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Noise Suppression" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="AI-powered background noise removal" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='10' x:Name="NoiseSuppressionToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Echo Cancellation" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Reduce echo and feedback from speakers" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='9' x:Name="EchoCancelToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Audio Bitrate" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Quality of audio encoding" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='8' x:Name="AudioBitrateCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="140" SelectedIndex="1">
                                    <ComboBoxItem Content="128 kbps"/>
                                    <ComboBoxItem Content="192 kbps"/>
                                    <ComboBoxItem Content="256 kbps"/>
                                    <ComboBoxItem Content="320 kbps"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Encoder & Performance -->
                <StackPanel Spacing="12">
                    <TextBlock Text="ENCODER &amp; PERFORMANCE" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Video Bitrate" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Target bitrate in kbps" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='7' x:Name="VideoBitrateCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="160" SelectedIndex="2">
                                    <ComboBoxItem Content="4 Mbps (Low)"/>
                                    <ComboBoxItem Content="6 Mbps"/>
                                    <ComboBoxItem Content="8 Mbps (Recommended)"/>
                                    <ComboBoxItem Content="12 Mbps"/>
                                    <ComboBoxItem Content="20 Mbps (High)"/>
                                    <ComboBoxItem Content="50 Mbps (Lossless)"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Encoder Preset" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Quality vs performance trade-off" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='6' x:Name="EncoderPresetCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="160" SelectedIndex="1">
                                    <ComboBoxItem Content="Fast (Low quality)"/>
                                    <ComboBoxItem Content="Balanced"/>
                                    <ComboBoxItem Content="Quality (Slow)"/>
                                    <ComboBoxItem Content="Lossless"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Recording Behaviour -->
                <StackPanel Spacing="12">
                    <TextBlock Text="RECORDING BEHAVIOUR" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <Grid Padding="0,4" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Countdown Duration" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Seconds before recording starts" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ComboBox x:ConnectionId='5' x:Name="CountdownDurCombo" Grid.Column="1" Style="{StaticResource AlvoniaComboBoxStyle}" Width="120" SelectedIndex="1">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="3 seconds"/>
                                    <ComboBoxItem Content="5 seconds"/>
                                    <ComboBoxItem Content="10 seconds"/>
                                </ComboBox>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Pause/Resume Sound" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Play a sound when pausing or resuming" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='4' x:Name="PauseResumeSoundToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <Grid Padding="0,12,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Recording Indicator" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Show red border on screen while recording" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='3' x:Name="RecordingIndicatorToggle" Grid.Column="1" IsOn="True" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Keyboard Shortcuts -->
                <StackPanel Spacing="12">
                    <TextBlock Text="KEYBOARD SHORTCUTS" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel>
                            <ItemsControl>
                                <ItemsControl.Items>
                                    <x:String>Start/Stop Recording|Ctrl+Shift+R</x:String>
                                    <x:String>Pause Recording|Ctrl+Shift+P</x:String>
                                    <x:String>Open Whiteboard|Ctrl+Shift+W</x:String>
                                    <x:String>Take Screenshot|Ctrl+Shift+S</x:String>
                                    <x:String>Minimize to Tray|Ctrl+M</x:String>
                                </ItemsControl.Items>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,8" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" Grid.Column="0"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- About -->
                <StackPanel Spacing="12">
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="48" Height="48" CornerRadius="12"
                                        Background="{StaticResource BrandPrimaryBrush}">
                                    <TextBlock Text="R" Foreground="White" FontWeight="Bold"
                                               FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="RecordIt" FontWeight="Bold" FontSize="18"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Version 1.0.0 · Alvonia UI · WinUI 3"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                RecordIt is a screen recording and whiteboard collaboration tool
                                built with Alvonia UI design system on WinUI 3. Perfect for tutorials,
                                demos, and team collaboration.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <HyperlinkButton Content="Website" Foreground="{StaticResource BrandPrimaryBrush}" />
                                <HyperlinkButton Content="Privacy Policy" Foreground="{StaticResource TextSecondaryBrush}" />
                                <HyperlinkButton Content="Changelog" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

