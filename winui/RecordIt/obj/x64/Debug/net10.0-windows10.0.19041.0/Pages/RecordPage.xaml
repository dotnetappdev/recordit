<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecordIt.Pages.RecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBaseBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border Grid.Row="0"
                Padding="24,20"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Screen Recorder"
                               Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Capture your screen, window, or application"
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>
                <Button x:ConnectionId='26' Grid.Column="1"
                        x:Name="RefreshSourcesBtn"
                        Style="{StaticResource AlvoniaGhostButtonStyle}"
                                                       >
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="13" />
                        <TextBlock Text="Refresh Sources" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Page Body -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="16">

                <!-- Source Selection -->
                <Border Style="{StaticResource AlvoniaCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7F8;" FontSize="16"
                                      Foreground="{StaticResource BrandPrimaryBrush}" />
                            <TextBlock Text="Capture Source" FontWeight="SemiBold" FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <GridView x:ConnectionId='23' x:Name="SourcesGridView"
                                  SelectionMode="Single"
                                                              
                                  IsItemClickEnabled="True">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"
                                                   MaximumRowsOrColumns="4" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="200" CornerRadius="10"
                                            Background="{StaticResource BgElevatedBrush}"
                                            Margin="4">
                                        <StackPanel>
                                            <Border Height="112" CornerRadius="8,8,0,0"
                                                    Background="{StaticResource BgOverlayBrush}">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Padding="10,6"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <!-- Empty state -->
                        <StackPanel x:ConnectionId='24' x:Name="EmptySourcesState"
                                    HorizontalAlignment="Center"
                                    Spacing="8"
                                    Padding="40"
                                    Visibility="Collapsed">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7F8;" FontSize="40"
                                      Foreground="{StaticResource TextTertiaryBrush}"
                                      HorizontalAlignment="Center" />
                            <TextBlock Text="No sources found"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Click Refresh Sources to scan for available capture sources."
                                       FontSize="13"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Settings Row -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Quality Settings -->
                    <Border Grid.Column="0" Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FE;" FontSize="16"
                                          Foreground="{StaticResource BrandPrimaryBrush}" />
                                <TextBlock Text="Quality Settings" FontWeight="SemiBold" FontSize="15"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Resolution" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <ComboBox x:ConnectionId='22' x:Name="QualityCombo"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          HorizontalAlignment="Stretch"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="1080p HD" />
                                    <ComboBoxItem Content="1440p QHD" />
                                    <ComboBoxItem Content="4K Ultra HD" />
                                    <ComboBoxItem Content="720p" />
                                    <ComboBoxItem Content="480p" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Frame Rate" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <ComboBox x:ConnectionId='21' x:Name="FpsCombo"
                                          Style="{StaticResource AlvoniaComboBoxStyle}"
                                          HorizontalAlignment="Stretch"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="60 fps" />
                                    <ComboBoxItem Content="30 fps" />
                                    <ComboBoxItem Content="24 fps" />
                                    <ComboBoxItem Content="15 fps" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Audio & Camera -->
                    <Border Grid.Column="1" Style="{StaticResource AlvoniaCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Audio &amp; Camera" FontWeight="SemiBold" FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <Grid Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Microphone" FontWeight="Medium" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Record system audio &amp; mic" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <ToggleSwitch x:ConnectionId='20' x:Name="MicToggle"
                                             Grid.Column="1"
                                             IsOn="True"
                                             Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="0,1,0,0" />

                            <Grid Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Camera Overlay" FontWeight="Medium" FontSize="14"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Show webcam in corner" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <ToggleSwitch x:ConnectionId='18' x:Name="CameraToggle" IsOn="False" Style="{StaticResource AlvoniaToggleSwitchStyle}" />
                                    <ComboBox x:ConnectionId='19' x:Name="WebcamDeviceCombo" Style="{StaticResource AlvoniaComboBoxStyle}" Width="200" Margin="0,8,0,0">
                                        <ComboBoxItem Content="Default" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <Grid Padding="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Microphone Device" FontWeight="Medium" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Choose microphone / loopback device" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <ComboBox x:ConnectionId='16' x:Name="MicDeviceCombo" Style="{StaticResource AlvoniaComboBoxStyle}" Width="200">
                                        <ComboBoxItem Content="Default" />
                                    </ComboBox>
                                    <Button x:ConnectionId='17' x:Name="ProbeDevicesBtn" Style="{StaticResource AlvoniaGhostButtonStyle}"                               Margin="0,8,0,0">Probe Devices</Button>
                                </StackPanel>
                            </Grid>
                            <Grid Padding="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Preview" FontWeight="Medium" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Open preview windows for display / webcam (uses ffplay)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button x:ConnectionId='14' x:Name="StartPreviewBtn" Style="{StaticResource AlvoniaGhostButtonStyle}"                              >Start Preview</Button>
                                    <Button x:ConnectionId='15' x:Name="StopPreviewBtn" Style="{StaticResource AlvoniaGhostButtonStyle}"                             >Stop Preview</Button>
                                </StackPanel>
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0" />
                            <StackPanel Padding="8,12,8,0">
                                <TextBlock Text="Additional Audio Tracks (SFX / Music)" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button x:ConnectionId='12' x:Name="AddAudioTrackBtn" Style="{StaticResource AlvoniaGhostButtonStyle}"                               >Add Track</Button>
                                    <Button x:ConnectionId='13' x:Name="ClearAudioTracksBtn" Style="{StaticResource AlvoniaGhostButtonStyle}"                                  >Clear</Button>
                                </StackPanel>
                                <ListView x:ConnectionId='11' x:Name="AudioTracksList" Height="80" Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Docked Preview (embedded ffplay) -->
        <Border x:ConnectionId='2' Grid.Row="1" x:Name="PreviewHost" Width="420" Height="240" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,32,32,0" Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Preview" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="(docked ffplay)" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
        <!-- Recording Controls Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Record/Stop button -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Button x:ConnectionId='8' x:Name="StartRecordBtn"
                            Style="{StaticResource AlvoniaRecordButtonStyle}"
                                                        >
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="16" Height="16" Fill="White" />
                            <TextBlock Text="Start Recording" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='9' x:Name="StopRecordBtn"
                            Visibility="Collapsed"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                                                       
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="24,12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;"
                                      FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Stop Recording"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Button>

                    <TextBlock x:ConnectionId='10' x:Name="RecordHintText"
                               Text="Select a capture source first"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                </StackPanel>

                <!-- Right controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button x:ConnectionId='3' x:Name="ExportBtn"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                                                   
                            ToolTipService.ToolTip="Export recording">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="16" />
                    </Button>
                    <Button x:ConnectionId='4' x:Name="MicBtn"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                                                
                            ToolTipService.ToolTip="Toggle Microphone">
                        <FontIcon x:ConnectionId='7' x:Name="MicIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE720;" FontSize="16"
                                  Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                    <Button x:ConnectionId='5' x:Name="CamBtn"
                            Style="{StaticResource AlvoniaGhostButtonStyle}"
                                                
                            ToolTipService.ToolTip="Toggle Camera">
                        <FontIcon x:ConnectionId='6' x:Name="CamIcon" FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE714;" FontSize="16"
                                  Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

