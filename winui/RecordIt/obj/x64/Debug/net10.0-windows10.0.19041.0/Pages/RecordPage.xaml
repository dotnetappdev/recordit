<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="RecordIt.Pages.RecordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:RecordIt.Converters"
    xmlns:media="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Background="{StaticResource BgBaseBrush}"
    FontSize="12">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Menu bar -->
            <RowDefinition Height="*"    />  <!-- Preview -->
            <RowDefinition Height="Auto" />  <!-- Timeline -->
            <RowDefinition Height="Auto" />  <!-- Effects -->
            <RowDefinition Height="220"  />  <!-- Docks (panels) -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 0 · Menu Bar (OBS-style)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,0,0,1">
            <MenuBar>

                <!-- File -->
                <MenuBarItem Title="File">
                    <MenuFlyoutItem x:ConnectionId='134' x:Name="MenuNewScene"    Text="New Scene Collection"                              />
                    <MenuFlyoutItem x:ConnectionId='135' x:Name="MenuOpenScene"   Text="Open Scene Collection…"                             />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='136' x:Name="MenuStartRecord" Text="Start Recording"                                     />
                    <MenuFlyoutItem x:ConnectionId='137' x:Name="MenuStopRecord"  Text="Stop Recording"                                      IsEnabled="False" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='138' x:Name="MenuExport"      Text="Show in Library"                                 />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='139' x:Name="MenuExit"        Text="Exit"                                          />
                </MenuBarItem>

                <!-- Edit -->
                <MenuBarItem Title="Edit">
                    <MenuFlyoutItem x:ConnectionId='131' x:Name="MenuSettings" Text="Settings…"                            />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='132' x:Name="MenuAddScene"  Text="Add Scene"                            />
                    <MenuFlyoutItem x:ConnectionId='133' x:Name="MenuAddSource" Text="Add Source…"                            />
                </MenuBarItem>

                <!-- View -->
                <MenuBarItem Title="View">
                    <MenuFlyoutItem x:ConnectionId='125' x:Name="MenuFullscreen" Text="Fullscreen Preview"                                />
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:ConnectionId='126' x:Name="MenuShowScenes"     Text="Scenes Panel"       IsChecked="True"                                Tag="scenes" />
                    <ToggleMenuFlyoutItem x:ConnectionId='127' x:Name="MenuShowSources"    Text="Sources Panel"      IsChecked="True"                                Tag="sources" />
                    <ToggleMenuFlyoutItem x:ConnectionId='128' x:Name="MenuShowMixer"      Text="Audio Mixer"        IsChecked="True"                                Tag="mixer" />
                    <ToggleMenuFlyoutItem x:ConnectionId='129' x:Name="MenuShowTransitions" Text="Transitions Panel"  IsChecked="True"                                Tag="transitions" />
                    <ToggleMenuFlyoutItem x:ConnectionId='130' x:Name="MenuShowControls"   Text="Controls Panel"     IsChecked="True"                                Tag="controls" />
                </MenuBarItem>

                <!-- Docks -->
                <MenuBarItem Title="Docks">
                    <MenuFlyoutItem x:ConnectionId='121' Text="Lock Docks"                                     />
                    <MenuFlyoutItem x:ConnectionId='122' Text="Reset Dock Layout"                                />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='123' Text="Refresh Sources"                                    />
                    <MenuFlyoutItem x:ConnectionId='124' Text="Probe Audio Devices"                               />
                </MenuBarItem>

                <!-- Tools -->
                <MenuBarItem Title="Tools">
                    <MenuFlyoutItem x:ConnectionId='117' x:Name="MenuWhiteboard" Text="Whiteboard"                               />
                    <MenuFlyoutItem x:ConnectionId='118' x:Name="MenuLibrary"    Text="Library"                               />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:ConnectionId='119' x:Name="MenuStartPreview" Text="Start Preview"                                />
                    <MenuFlyoutItem x:ConnectionId='120' x:Name="MenuStopPreview"  Text="Stop Preview"                                />
                </MenuBarItem>

                <!-- Help -->
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem x:ConnectionId='116' Text="About RecordIt"                         />
                </MenuBarItem>

            </MenuBar>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 1 · Preview Area
             Normal mode  : [PREVIEW *] | [Live side 360px]
             Studio mode  : [PREVIEW *] | [4px] | [PROGRAM *]
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:ConnectionId='2' x:Name="PreviewAreaGrid" Grid.Row="1" Background="#080808">
            <Grid.ColumnDefinitions>
                <!-- col 0: PREVIEW / main canvas -->
                <ColumnDefinition x:ConnectionId='75' x:Name="PreviewMainCol" Width="*" />
                <!-- col 1: studio divider (0 in normal mode) -->
                <ColumnDefinition x:ConnectionId='76' x:Name="StudioDivCol" Width="0" />
                <!-- col 2: PROGRAM panel (0 in normal mode) -->
                <ColumnDefinition x:ConnectionId='77' x:Name="ProgramCol" Width="0" />
                <!-- col 3: small live-preview side panel (360 in normal mode) -->
                <ColumnDefinition x:ConnectionId='78' x:Name="LiveSideCol" Width="360" />
            </Grid.ColumnDefinitions>

            <!-- ── col 0: Main PREVIEW canvas ─────────────────────────── -->
            <Border x:ConnectionId='79' x:Name="PreviewHost"
                    Grid.Column="0"
                    Background="#000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- Screen-capture live feed (WGC frames → SoftwareBitmapSource) -->
                    <Image x:ConnectionId='112' x:Name="PreviewScreenImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Visibility="Collapsed" />

                    <!-- Webcam / video-device live feed -->
                    <media:MediaPlayerElement x:ConnectionId='113' x:Name="PreviewVideoElement"
                                              AreTransportControlsEnabled="False"
                                              AutoPlay="False"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              Visibility="Collapsed" />

                    <!-- Hint shown when no source is active -->
                    <StackPanel x:ConnectionId='114' x:Name="PreviewHintPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;"
                                  FontSize="40" Foreground="#22FFFFFF"
                                  HorizontalAlignment="Center" />
                        <TextBlock x:ConnectionId='115' x:Name="PreviewHintText"
                                   Text="No source selected"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#33FFFFFF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── col 1: Studio divider line ────────────────────────── -->
            <Rectangle x:ConnectionId='80' x:Name="StudioDividerRect"
                       Grid.Column="1"
                       Fill="#222222"
                       Visibility="Collapsed" />

            <!-- ── col 2: PROGRAM panel (Studio Mode only) ────────────── -->
            <Border x:ConnectionId='81' x:Name="ProgramHost"
                    Grid.Column="2"
                    Background="#050505"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Visibility="Collapsed">
                <Grid>
                    <!-- placeholder / live output info -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE9D5;"
                                  FontSize="40" Foreground="#22FF4444"
                                  HorizontalAlignment="Center" />
                        <TextBlock x:ConnectionId='111' x:Name="ProgramHintText"
                                   Text="No program output"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#33FFFFFF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Webcam live preview in PROGRAM pane -->
                    <media:MediaPlayerElement x:ConnectionId='109' x:Name="ProgramCamElement"
                                              AreTransportControlsEnabled="False"
                                              AutoPlay="False"
                                              Stretch="UniformToFill"
                                              Visibility="Collapsed" />

                    <!-- PROGRAM label overlay -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="12,10" Padding="10,4"
                            Background="#CC1A0000"
                            CornerRadius="6"
                            BorderBrush="#55EF4444" BorderThickness="1">
                        <TextBlock Text="PROGRAM"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#CCEF4444"
                                   CharacterSpacing="80" />
                    </Border>

                    <!-- Transition button (centre-top of program pane) -->
                    <Button x:ConnectionId='110' x:Name="TransitionBtn"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,10,12,0"
                            Style="{StaticResource AlvoniaRecordButtonStyle}"
                                                       
                            ToolTipService.ToolTip="Cut — push Preview to Program">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8AB;" FontSize="11" />
                            <TextBlock Text="CUT" VerticalAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── col 3: Small Live Preview panel (normal mode) ──────── -->
                <!-- Drag splitter placed at the left edge of the live side panel -->
                    <Border x:ConnectionId='82' Grid.Column="3" x:Name="PreviewLiveSplitter"
                        Width="8" HorizontalAlignment="Left" Background="Transparent"
                                                                           
                                                                       
                                                                             
                                                                           
                                                                         
                        ToolTipService.ToolTip="Drag to resize preview" />

                <Border x:ConnectionId='83' Grid.Column="3" x:Name="LivePreviewHost"
                    Background="#0A0000" BorderBrush="#151515" BorderThickness="1,0,0,0"
                    Padding="6">
                <controls:TabView>
                    <controls:TabView.Resources>
                        <Style TargetType="controls:TabViewItem">
                            <Setter Property="MinWidth" Value="68" />
                            <Setter Property="MinHeight" Value="28" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </controls:TabView.Resources>
                    <controls:TabViewItem Header="Live">
                        <Grid Padding="6">
                            <StackPanel Spacing="6">
                                <TextBlock Text="LIVE PREVIEW" FontSize="11" FontWeight="Bold" Foreground="#AAFFFFFF" />

                                <!-- Screen-capture live feed -->
                                <Image x:ConnectionId='106' x:Name="LivePreviewScreenImage"
                                       Stretch="UniformToFill"
                                       Height="200"
                                       Visibility="Collapsed" />

                                <!-- Webcam live feed via MediaPlayer -->
                                <media:MediaPlayerElement x:ConnectionId='107' x:Name="LivePreviewElement"
                                                          AreTransportControlsEnabled="False"
                                                          AutoPlay="False"
                                                          Stretch="UniformToFill"
                                                          Height="200"
                                                          Visibility="Collapsed" />

                                <TextBlock x:ConnectionId='108' x:Name="LivePreviewHint"
                                           Text="No live source"
                                           FontSize="12"
                                           Foreground="#66FFFFFF" />
                            </StackPanel>
                        </Grid>
                    </controls:TabViewItem>
                    <controls:TabViewItem x:ConnectionId='96' Header="Vertical" x:Name="VerticalTabItem">
                        <Grid Padding="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="VERTICAL PREVIEW" FontSize="11" FontWeight="Bold" Foreground="#AAFFFFFF" />
                                <Button x:ConnectionId='105' x:Name="VerticalUndockBtn" Content="Undock" Grid.Column="1" Margin="6,0,0,0"                                 />
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="240" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#000" Padding="6">
                                    <Image x:ConnectionId='104' x:Name="VerticalPreviewImage" Stretch="UniformToFill" Visibility="Visible" Height="360" Width="240" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Vertical Sources" FontWeight="SemiBold" />
                                    <ListBox x:ConnectionId='97' x:Name="VerticalSourcesList" Height="180"                                                         />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button x:ConnectionId='101' Content="Add"                                    />
                                        <Button x:ConnectionId='102' Content="Remove"                                       />
                                        <Button x:ConnectionId='103' Content="Settings"                                         />
                                    </StackPanel>
                                    <TextBlock Text="Scenes" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    <ListBox x:ConnectionId='98' x:Name="VerticalScenesList" Height="100" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button x:ConnectionId='99' Content="Add Scene"                                   />
                                        <Button x:ConnectionId='100' Content="Remove Scene"                                      />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </controls:TabViewItem>
                </controls:TabView>
            </Border>

            <!-- ── Overlays on column 0 ───────────────────────────────── -->

            <!-- PREVIEW label top-left -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="12,10" Padding="10,4"
                    Background="#CC000000"
                    CornerRadius="6"
                    BorderBrush="#22FFFFFF" BorderThickness="1">
                <TextBlock x:ConnectionId='95' x:Name="PreviewLabelText"
                           Text="PREVIEW"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#AAFFFFFF"
                           CharacterSpacing="80" />
            </Border>

            <!-- Small record button in preview overlay -->
            <Button x:ConnectionId='84' x:Name="PreviewRecordBtn"
                    Grid.Column="0"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="12,50,0,0"
                    Style="{StaticResource AlvoniaRecordButtonStyle}"
                                                >
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="6" Height="6" Fill="White" VerticalAlignment="Center" />
                    <TextBlock Text="Record" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Button>

            <!-- Recording status overlay (top-right of column 0) -->
            <Border x:ConnectionId='85' x:Name="RecordingBadge"
                    Grid.Column="0"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,12,0" Padding="10,4"
                    Background="#CC1A0000"
                    CornerRadius="6"
                    BorderBrush="#55EF4444" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#FFEF4444" />
                    <TextBlock x:ConnectionId='94' x:Name="RecordingTimerText"
                               Text="00:00"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#FFEF4444"
                               FontFamily="Cascadia Code, Consolas" />
                </StackPanel>
            </Border>

            <!-- ── Caption overlay (above scene strip) ───────────────── -->
            <Border x:ConnectionId='86' x:Name="CaptionOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="40,0,40,48"
                    Padding="18,8"
                    Background="#8C000000"
                    CornerRadius="8"
                    BorderBrush="#33FFFFFF" BorderThickness="1"
                    Visibility="Collapsed"
                    MaxWidth="900">
                <TextBlock x:ConnectionId='93' x:Name="CaptionText"
                           Text=""
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>

            <!-- ── Countdown overlay (centred, shown 3-2-1) ───────────── -->
            <Border x:ConnectionId='87' x:Name="CountdownOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="120" Height="120"
                    Background="#CC000000"
                    CornerRadius="60"
                    BorderBrush="#44FFFFFF" BorderThickness="2"
                    Visibility="Collapsed">
                <TextBlock x:ConnectionId='92' x:Name="CountdownText"
                           Text="3"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- ── Lower-Third / Title card overlay ──────────────── -->
            <Border x:ConnectionId='88' x:Name="LowerThirdOverlay"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                    Margin="0,0,0,36"
                    Padding="20,10,20,12"
                    Background="#E6000000"
                    BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0"
                    Visibility="Collapsed">
                <StackPanel Spacing="2">
                    <TextBlock x:ConnectionId='90' x:Name="LowerThirdTitle"
                               Text="Title Text"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock x:ConnectionId='91' x:Name="LowerThirdSub"
                               Text="Subtitle / Role"
                               FontSize="13"
                               Foreground="#B3FFFFFF" />
                </StackPanel>
            </Border>

            <!-- Scene selector quick strip (bottom of preview) -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                    Background="#CC000000" Padding="12,6"
                    BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
                <ScrollViewer HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Hidden">
                    <StackPanel x:ConnectionId='89' x:Name="SceneQuickBar"
                                Orientation="Horizontal" Spacing="6" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 2 · Timeline View (between preview and docks)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:ConnectionId='3' x:Name="TimelinePanel" Grid.Row="2"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,1,0,0"
                Height="130">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Timeline toolbar -->
                <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Playback controls -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Go to start"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" FontSize="10" />
                            </Button>
                            <Button x:ConnectionId='72' x:Name="TimelinePlayBtn" Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Play/Pause"
                                    Width="22" Height="22"                              >
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Go to end"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" FontSize="10" />
                            </Button>

                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="4,0" />

                            <TextBlock x:ConnectionId='73' x:Name="TimelinePositionText" Text="00:00.0"
                                       FontSize="11" FontWeight="Bold" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="/" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="4,0" />
                            <TextBlock x:ConnectionId='74' x:Name="TimelineDurationText" Text="05:00.0"
                                       FontSize="11" FontFamily="Cascadia Code, Consolas"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Timeline actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <Button x:ConnectionId='70' Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Add marker"
                                                                       Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Split at playhead"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C6;" FontSize="10" />
                            </Button>
                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Zoom out timeline"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71F;" FontSize="10" />
                            </Button>
                            <Button Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Zoom in timeline"
                                    Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A3;" FontSize="10" />
                            </Button>
                            <Border Width="1" Height="14" Background="{StaticResource BorderDefaultBrush}" Margin="2,0" />
                            <Button x:ConnectionId='71' x:Name="EffectsToggleBtn" Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Toggle effects panel"
                                                                   Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" FontSize="10" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timeline tracks area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Track labels -->
                    <StackPanel Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                                BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,1,0">
                        <Border Height="18" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1" />
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Video 1" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Video 2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Audio 1" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                        <Border Height="24" Padding="6,0" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Audio 2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <!-- Tracks + Playhead canvas -->
                    <Canvas x:ConnectionId='69' x:Name="TimelineCanvas" Grid.Column="1" Background="Transparent">
                        <!-- Ruler and clips drawn in code-behind -->
                    </Canvas>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 3 · Effects Panel (collapsible)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:ConnectionId='4' x:Name="EffectsPanel" Grid.Row="3"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderPanelBrush}"
                BorderThickness="0,1,0,0"
                Visibility="Collapsed"
                Height="120">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderPanelBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE771;" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="EFFECTS" FontSize="10" FontWeight="Bold" CharacterSpacing="80"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                            <Button x:ConnectionId='67' Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Add effect"
                                                               Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="10" />
                            </Button>
                            <Button x:ConnectionId='68' Style="{StaticResource ObsToolbarBtnStyle}" ToolTipService.ToolTip="Close effects"
                                                                   Width="22" Height="22">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="10" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Auto" Padding="6,4">
                    <StackPanel x:ConnectionId='66' x:Name="EffectsStack" Orientation="Horizontal" Spacing="8">
                        <!-- Effect cards: Blur, Chroma Key, Color Correction, Vignette, Sharpen, etc. -->
                        <Border Background="#1A6366F1" BorderBrush="#336366F1" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Background Blur" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Gaussian blur" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A22C55E" BorderBrush="#3322C55E" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Green Screen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Chroma key removal" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="75" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AF59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Color Correct" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="White balance / tones" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AEF4444" BorderBrush="#33EF4444" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Vignette" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Dark edges cinematic" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="40" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A8B5CF6" BorderBrush="#338B5CF6" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Sharpen" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Enhance edge detail" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="30" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1A06B6D4" BorderBrush="#3306B6D4" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Noise Reduction" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Reduce video grain" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="60" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AFBBF24" BorderBrush="#33FBBF24" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Brightness" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Brightness / contrast" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                        <Border Background="#1AEC4899" BorderBrush="#33EC4899" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="140">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Saturation" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Color vibrance" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <Slider Minimum="0" Maximum="100" Value="50" Height="24" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Row 4 · Docked Panels
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="4"
              Background="{StaticResource BgPanelBrush}"
              BorderBrush="{StaticResource BorderPanelBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:ConnectionId='13' x:Name="ScenesColumn"    Width="175" MinWidth="100" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:ConnectionId='14' x:Name="SourcesColumn"   Width="200" MinWidth="120" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:ConnectionId='15' x:Name="MixerColumn"     Width="*"   MinWidth="200" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:ConnectionId='16' x:Name="TransColumn"     Width="155" MinWidth="100" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition x:ConnectionId='17' x:Name="ControlsColumn"  Width="155" MinWidth="130" />
            </Grid.ColumnDefinitions>

            <!-- ── Panel: Scenes ──────────────────────────────────────── -->
            <Grid x:ConnectionId='18' x:Name="ScenesPanel" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <TextBlock Text="SCENES" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                </Border>

                <ListView x:ConnectionId='60' Grid.Row="1"
                          x:Name="ScenesList"
                          Background="Transparent"
                          ItemContainerStyle="{StaticResource ObsListItemStyle}"
                                                                        
                          Padding="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='61' Style="{StaticResource ObsToolbarBtnStyle}"
                                                         
                                ToolTipService.ToolTip="Add Scene">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button x:ConnectionId='62' Style="{StaticResource ObsToolbarBtnStyle}"
                                                            
                                ToolTipService.ToolTip="Remove Scene">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="11" />
                        </Button>
                        <Button x:ConnectionId='63' Style="{StaticResource ObsToolbarBtnStyle}"
                                                        
                                ToolTipService.ToolTip="Move Up">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;" FontSize="10" />
                        </Button>
                        <Button x:ConnectionId='64' Style="{StaticResource ObsToolbarBtnStyle}"
                                                          
                                ToolTipService.ToolTip="Move Down">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Style="{StaticResource PanelSeparatorStyle}" />

            <!-- ── Panel: Sources ─────────────────────────────────────── -->
            <Grid x:ConnectionId='19' x:Name="SourcesPanel" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <TextBlock Text="SOURCES" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                </Border>

                <!-- Sources list + empty-state overlay share the same cell -->
                <Grid Grid.Row="1">

                    <ListView x:ConnectionId='57' x:Name="SourcesList"
                              Background="Transparent"
                              ItemContainerStyle="{StaticResource ObsListItemStyle}"
                                                                             
                              Padding="2">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="{Binding Icon}"
                                              FontSize="11"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <!-- Visibility eye icon -->
                                    <FontIcon Grid.Column="2"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="&#xE7B3;"
                                              FontSize="10"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                    <!-- Lock icon -->
                                    <FontIcon Grid.Column="3"
                                              FontFamily="Segoe MDL2 Assets"
                                              Glyph="&#xE72E;"
                                              FontSize="10"
                                              Foreground="{StaticResource TextTertiaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty-state overlay — visible when scene has no sources -->
                    <Border x:ConnectionId='58' x:Name="SourcesEmptyState"
                            Visibility="Visible"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Margin="12">
                            <!-- Dashed question-mark icon -->
                            <Border Width="40" Height="40"
                                    CornerRadius="6"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1.5"
                                    HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE897;"
                                          FontSize="18"
                                          Foreground="#44FFFFFF"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="You don't have any sources."
                                       FontSize="11"
                                       Foreground="#99FFFFFF"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Click the + button below,"
                                       FontSize="10"
                                       Foreground="#AA6EA0FF"
                                       TextAlignment="Center" />
                            <TextBlock Text="or right click here to add one."
                                       FontSize="10"
                                       Foreground="#AA6EA0FF"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                </Grid>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='52' Style="{StaticResource ObsToolbarBtnStyle}"
                                                          
                                ToolTipService.ToolTip="Add Source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button x:ConnectionId='53' Style="{StaticResource ObsToolbarBtnStyle}"
                                                             
                                ToolTipService.ToolTip="Remove Source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE738;" FontSize="11" />
                        </Button>
                        <Button x:ConnectionId='54' Style="{StaticResource ObsToolbarBtnStyle}"
                                                         
                                ToolTipService.ToolTip="Move Up">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;" FontSize="10" />
                        </Button>
                        <Button x:ConnectionId='55' Style="{StaticResource ObsToolbarBtnStyle}"
                                                           
                                ToolTipService.ToolTip="Move Down">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" FontSize="10" />
                        </Button>
                        <Button x:ConnectionId='56' Style="{StaticResource ObsToolbarBtnStyle}"
                                                               
                                ToolTipService.ToolTip="Source Settings">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Column="3" Style="{StaticResource PanelSeparatorStyle}" />

            <!-- ── Panel: Audio Mixer ─────────────────────────────────── -->
            <Grid x:ConnectionId='20' x:Name="MixerPanel" Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="AUDIO MIXER"
                                   Style="{StaticResource ObsPanelHeaderTextStyle}" />
                        <Button x:ConnectionId='51' Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                                             
                                ToolTipService.ToolTip="Refresh audio devices"
                                Height="18" Width="18">
                            <FontIcon FontFamily="Segoe MDL2 Assets"
                                      Glyph="&#xE72C;" FontSize="9" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Mixer channels - populated in code -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Hidden"
                              Padding="6,4">
                    <StackPanel x:ConnectionId='50' x:Name="AudioMixerChannels"
                                Orientation="Horizontal"
                                Spacing="2" />
                </ScrollViewer>

                <Border Grid.Row="2" Style="{StaticResource ObsPanelToolbarStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='48' Style="{StaticResource ObsToolbarBtnStyle}"
                                                              
                                ToolTipService.ToolTip="Add audio source">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="11" />
                        </Button>
                        <Button x:ConnectionId='49' Style="{StaticResource ObsToolbarBtnStyle}"
                                                                 
                                ToolTipService.ToolTip="Remove all audio sources">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="11" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Column="5" Style="{StaticResource PanelSeparatorStyle}" />

            <!-- ── Panel: Transitions / Options ───────────────────────── -->
            <Grid x:ConnectionId='21' x:Name="TransitionsPanel" Grid.Column="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <TextBlock Text="OPTIONS" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                </Border>

                <ScrollViewer Grid.Row="1" Padding="8,6">
                    <StackPanel Spacing="10">

                        <!-- Resolution -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="RESOLUTION"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <ComboBox x:ConnectionId='47' x:Name="QualityCombo"
                                      Style="{StaticResource AlvoniaComboBoxStyle}"
                                      HorizontalAlignment="Stretch"
                                      FontSize="12"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="1080p (1920×1080)" />
                                <ComboBoxItem Content="1440p (2560×1440)" />
                                <ComboBoxItem Content="4K (3840×2160)" />
                                <ComboBoxItem Content="720p (1280×720)" />
                                <ComboBoxItem Content="480p (854×480)" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Frame rate -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="FRAME RATE"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <ComboBox x:ConnectionId='46' x:Name="FpsCombo"
                                      Style="{StaticResource AlvoniaComboBoxStyle}"
                                      HorizontalAlignment="Stretch"
                                      FontSize="12"
                                      SelectedIndex="1">
                                <ComboBoxItem Content="60 fps" />
                                <ComboBoxItem Content="30 fps" />
                                <ComboBoxItem Content="24 fps" />
                                <ComboBoxItem Content="15 fps" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Camera overlay -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="CAMERA OVERLAY"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <ComboBox x:ConnectionId='45' x:Name="WebcamDeviceCombo"
                                      Style="{StaticResource AlvoniaComboBoxStyle}"
                                      HorizontalAlignment="Stretch"
                                      FontSize="12">
                                <ComboBoxItem Content="(disabled)" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Mic device -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="MIC / AUDIO INPUT"
                                       FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       CharacterSpacing="80" />
                            <ComboBox x:ConnectionId='44' x:Name="MicDeviceCombo"
                                      Style="{StaticResource AlvoniaComboBoxStyle}"
                                      HorizontalAlignment="Stretch"
                                      FontSize="12">
                                <ComboBoxItem Content="Default Microphone" IsSelected="True" />
                            </ComboBox>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Column="7" Style="{StaticResource PanelSeparatorStyle}" />

            <!-- ── Panel: Controls ────────────────────────────────────── -->
            <Grid x:ConnectionId='22' x:Name="ControlsPanel" Grid.Column="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ObsPanelHeaderStyle}">
                    <TextBlock Text="CONTROLS" Style="{StaticResource ObsPanelHeaderTextStyle}" />
                </Border>

                <StackPanel Grid.Row="1" Padding="8,8" Spacing="6">

                    <!-- Studio Mode toggle (OBS-style) -->
                    <Button x:ConnectionId='23' x:Name="StudioModeBtn"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                       
                            ToolTipService.ToolTip="Studio Mode: left = Preview, right = Program">
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B1;" FontSize="11" />
                            <TextBlock x:ConnectionId='43' x:Name="StudioModeBtnText" Text="Studio Mode" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Start / Stop Recording -->
                    <Button x:ConnectionId='24' x:Name="StartRecordBtn"
                            Style="{StaticResource AlvoniaRecordButtonStyle}"
                                                        >
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center" />
                            <TextBlock Text="Start Recording" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='25' x:Name="StopRecordBtn"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                       
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;"
                                      FontSize="11" Foreground="{StaticResource RecordingBrush}" />
                            <TextBlock Text="Stop Recording" />
                        </StackPanel>
                    </Button>

                    <!-- ── CC / Auto Captions ─────────────────────── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:ConnectionId='40' x:Name="CcBtn"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                                   
                                ToolTipService.ToolTip="Toggle live auto-captions (CC)">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7F0;" FontSize="11" />
                                <TextBlock x:ConnectionId='42' x:Name="CcBtnText" Text="Auto Captions" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='41' Grid.Column="1"
                                Style="{StaticResource ObsToolbarBtnStyle}"
                                                           
                                ToolTipService.ToolTip="Caption Settings"
                                Width="28" Height="28" Margin="4,0,0,0">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                        </Button>
                    </Grid>

                    <!-- ── Save Clip (Replay Buffer) ──────────────── -->
                    <Button x:ConnectionId='26' x:Name="SaveClipBtn"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                     
                            IsEnabled="False"
                            ToolTipService.ToolTip="Save the last 30 seconds as a clip">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="11" />
                            <TextBlock Text="Save Clip (30s)" />
                        </StackPanel>
                    </Button>

                    <!-- ── Lower Third / Title Card ──────────────── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:ConnectionId='37' x:Name="LowerThirdBtn"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                                           
                                ToolTipService.ToolTip="Show/hide lower-third title card overlay">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D2;" FontSize="11" />
                                <TextBlock x:ConnectionId='39' x:Name="LowerThirdBtnText" Text="Lower Third" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='38' Grid.Column="1"
                                Style="{StaticResource ControlsPanelBtnStyle}"
                                Width="32" Padding="0"
                                                                   
                                ToolTipService.ToolTip="Configure lower-third text">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                        </Button>
                    </Grid>

                    <!-- ── Recording options box ──────────────────── -->
                    <Border Background="#0AFFFFFF" CornerRadius="6" Padding="8,7"
                            BorderBrush="#1AFFFFFF" BorderThickness="1">
                        <StackPanel Spacing="5">
                            <!-- Countdown before recording -->
                            <CheckBox x:ConnectionId='35' x:Name="CountdownCheckBox"
                                      Content="3-2-1 countdown"
                                      FontSize="12" IsChecked="True" />
                            <!-- Noise suppression -->
                            <CheckBox x:ConnectionId='36' x:Name="NoiseSuppCheckBox"
                                      Content="Noise suppression"
                                      FontSize="12" IsChecked="False" />
                        </StackPanel>
                    </Border>

                    <!-- Separate MP3 audio track option -->
                    <Border Background="#0AFFFFFF"
                            CornerRadius="6" Padding="8,7"
                            BorderBrush="#1AFFFFFF" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <CheckBox x:ConnectionId='32' x:Name="SepAudioCheckBox"
                                      Content="Save separate audio (MP3)"
                                      FontSize="12"
                                      IsChecked="False" />
                            <StackPanel x:ConnectionId='33' x:Name="SepAudioOptions"
                                        Orientation="Horizontal" Spacing="8"
                                                                                       
                                                                                                 
                                                         >
                                <TextBlock Text="Bitrate" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <ComboBox x:ConnectionId='34' x:Name="Mp3BitrateCombo"
                                          FontSize="11" Height="28"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="128 kbps" Tag="128" />
                                    <ComboBoxItem Content="192 kbps" Tag="192" />
                                    <ComboBoxItem Content="256 kbps" Tag="256" />
                                    <ComboBoxItem Content="320 kbps — max quality" Tag="320" />
                                    <ComboBoxItem Content="All bitrates (128 / 192 / 256 / 320)" Tag="all" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button x:ConnectionId='27' x:Name="StartPreviewBtn"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                         >
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="11" />
                            <TextBlock Text="Start Preview" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='28' x:Name="StopPreviewBtn"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                        
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE769;" FontSize="11" />
                            <TextBlock Text="Stop Preview" />
                        </StackPanel>
                    </Button>

                    <!-- Divider -->
                    <Border Height="1"
                            Background="{StaticResource BorderDefaultBrush}"
                            Margin="0,2" />

                    <Button x:ConnectionId='29' Style="{StaticResource ControlsPanelBtnStyle}"
                                                      >
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" FontSize="11" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='30' x:Name="ExportBtn"
                            Style="{StaticResource ControlsPanelBtnStyle}"
                                                   >
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;" FontSize="11" />
                            <TextBlock Text="Open Library" />
                        </StackPanel>
                    </Button>

                    <!-- Status text -->
                    <TextBlock x:ConnectionId='31' x:Name="StatusText"
                               Text="Ready"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Floating Recording Toolbar (overlay, visible during recording)
        ═══════════════════════════════════════════════════════════════════ -->
        <Border x:ConnectionId='5' x:Name="FloatingToolbar"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,60,0,0"
                Background="#F00D0D0D"
                CornerRadius="12"
                BorderBrush="#336366F1" BorderThickness="1"
                Padding="6,4"
                Visibility="Collapsed"
                ManipulationMode="TranslateX,TranslateY"
                                                                     >
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- Drag handle -->
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE784;" FontSize="12"
                          Foreground="#66FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0" />

                <!-- Stop button -->
                <Button x:ConnectionId='6' x:Name="FloatingStopBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                    ToolTipService.ToolTip="Stop Recording"
                        Background="#26EF4444" Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;" FontSize="12" Foreground="#FFEF4444" />
                </Button>

                <!-- Timer -->
                <Border Padding="6,0" Background="#1AEF4444" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#FFEF4444" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='12' x:Name="FloatingTimerText" Text="00:00"
                                   FontSize="12" FontWeight="Bold" FontFamily="Cascadia Code, Consolas"
                                   Foreground="#FFEF4444" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Width="1" Height="20" Background="#333333" Margin="2,0" />

                <!-- Mic toggle -->
                <Button x:ConnectionId='7' x:Name="FloatingMicBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                     ToolTipService.ToolTip="Toggle Microphone"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="12" />
                </Button>

                <!-- Camera toggle -->
                <Button x:ConnectionId='8' x:Name="FloatingCamBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                     ToolTipService.ToolTip="Toggle Camera"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="12" />
                </Button>

                <Border Width="1" Height="20" Background="#333333" Margin="2,0" />

                <!-- Screen annotation / drawing -->
                <Button x:ConnectionId='9' x:Name="FloatingDrawBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                      ToolTipService.ToolTip="Screen Annotation"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" FontSize="12" />
                </Button>

                <!-- Zoom -->
                <Button x:ConnectionId='10' x:Name="FloatingZoomBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                      ToolTipService.ToolTip="Zoom"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71E;" FontSize="12" />
                </Button>

                <!-- Minimize toolbar -->
                <Button x:ConnectionId='11' x:Name="FloatingMinBtn" Style="{StaticResource ObsToolbarBtnStyle}"
                                                     ToolTipService.ToolTip="Minimize Toolbar"
                        Width="28" Height="28">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE921;" FontSize="12" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>

