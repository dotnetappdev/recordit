<?xml version="1.0" encoding="utf-8"?>
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="RecordIt.Avalonia.App">
  <Application.Styles>
    <!-- Avalonia Fluent base theme (provides default control styles) -->
    <fluent:FluentTheme />
    <!-- Alvonia UI design tokens + class-based overrides -->
    <StyleInclude Source="avares://RecordIt.Avalonia/Styles/AlvoniaTheme.axaml" />
  </Application.Styles>
</Application>
