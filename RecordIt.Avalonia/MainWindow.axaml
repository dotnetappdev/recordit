<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RecordIt.Avalonia.MainWindow"
        Title="RecordIt"
        MinWidth="1024"
        MinHeight="640"
        Width="1280"
        Height="720"
        Background="{StaticResource BgBaseBrush}">

  <Grid RowDefinitions="40,*">

    <!-- ═══════════════════════════════════════════════════════════════════
         Custom Title Bar
    ═══════════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <!-- Logo + App Name -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">
          <Border Width="24" Height="24"
                  Background="{StaticResource BrandPrimaryBrush}"
                  CornerRadius="4">
            <TextBlock Text="R" Foreground="White"
                       FontWeight="Bold" FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="RecordIt"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontWeight="SemiBold"
                     FontSize="15"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Recording Indicator (center) -->
        <StackPanel x:Name="RecordingIndicator"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="False">
          <Ellipse Width="8" Height="8" Fill="{StaticResource RecordingBrush}" />
          <TextBlock x:Name="RecordingTimeText"
                     Text="00:00"
                     Foreground="{StaticResource RecordingBrush}"
                     FontWeight="SemiBold"
                     FontSize="13"
                     FontFamily="Cascadia Code,Consolas,monospace" />
          <Border Background="#1AEF4444"
                  BorderBrush="#4DEF4444"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="6,2">
            <TextBlock Text="REC"
                       Foreground="{StaticResource RecordingBrush}"
                       FontWeight="ExtraBold"
                       FontSize="10" />
          </Border>
        </StackPanel>

        <!-- Title bar right controls -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center">
          <Button x:Name="ThemeToggleBtn"
                  Classes="ghost"
                  Width="32" Height="28"
                  Padding="0"
                  Content="🌙"
                  FontSize="14"
                  Click="ThemeToggleBtn_Click"
                  ToolTip.Tip="Toggle Theme" />
          <Button Classes="ghost"
                  Width="32" Height="28"
                  Padding="0"
                  Content="—"
                  Click="MinimizeBtn_Click" />
          <Button Classes="ghost"
                  Width="32" Height="28"
                  Padding="0"
                  Content="□"
                  Click="MaximizeBtn_Click" />
          <Button Classes="ghost"
                  Width="32" Height="28"
                  Padding="0"
                  Content="✕"
                  Click="CloseBtn_Click" />
        </StackPanel>

      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════════
         Main Body
    ═══════════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" ColumnDefinitions="56,*">

      <!-- Sidebar -->
      <Border Grid.Column="0"
              Background="{StaticResource BgSurfaceBrush}"
              BorderBrush="{StaticResource BorderDefaultBrush}"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">

          <!-- Nav items -->
          <StackPanel Grid.Row="0" Spacing="2" Margin="8">
            <Button x:Name="RecordNavBtn"
                    Classes="sidebar"
                    Click="RecordNavBtn_Click"
                    ToolTip.Tip="Studio">
              <TextBlock Text="⏺"
                         FontSize="18"
                         Foreground="{StaticResource BrandPrimaryBrush}" />
            </Button>
            <Button x:Name="WhiteboardNavBtn"
                    Classes="sidebar"
                    Click="WhiteboardNavBtn_Click"
                    ToolTip.Tip="Whiteboard">
              <TextBlock Text="✏"
                         FontSize="18"
                         Foreground="{StaticResource TextTertiaryBrush}" />
            </Button>
            <Button x:Name="LibraryNavBtn"
                    Classes="sidebar"
                    Click="LibraryNavBtn_Click"
                    ToolTip.Tip="Library">
              <TextBlock Text="📁"
                         FontSize="18"
                         Foreground="{StaticResource TextTertiaryBrush}" />
            </Button>
          </StackPanel>

          <!-- Settings at bottom -->
          <Button Grid.Row="1"
                  x:Name="SettingsNavBtn"
                  Classes="sidebar"
                  Click="SettingsNavBtn_Click"
                  ToolTip.Tip="Settings"
                  Margin="8,0,8,8">
            <TextBlock Text="⚙"
                       FontSize="18"
                       Foreground="{StaticResource TextTertiaryBrush}" />
          </Button>

        </Grid>
      </Border>

                <!-- Content area: OBS-like dockable layout with splitters and tabs -->
                <Grid Grid.Column="1" Background="{StaticResource BgBaseBrush}">
                        <!-- Columns: Scenes/Sources | Main Preview area | Right Column -->
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <!-- Rows: Top (preview/program) | Bottom (mixer/controls) -->
                        <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <!-- Left column: Scenes (top) and Sources (bottom tabs) -->
                        <Grid Grid.Row="0" Grid.Column="0" RowSpan="2" Background="{StaticResource BgSurfaceBrush}"
                                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="260" />
                                </Grid.RowDefinitions>

                                <!-- Scenes list (like OBS) -->
                                <Border Grid.Row="0" Padding="8">
                                        <StackPanel Spacing="6">
                                                <TextBlock Text="Scenes" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <ListBox x:Name="ScenesList" Height="400" />
                                        </StackPanel>
                                </Border>

                                <!-- Sources consolidated with tabs -->
                                <Border Grid.Row="1" Padding="8" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderSubtleBrush}">
                                        <StackPanel Spacing="6">
                                                <TextBlock Text="Sources" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TabControl x:Name="SourcesTabs" Margin="0,6,0,0">
                                                        <TabItem Header="Displays">
                                                                <StackPanel Padding="6">
                                                                        <TextBlock Text="Select a display to capture" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                                                                        <ListBox x:Name="DisplayList" Height="120" />
                                                                </StackPanel>
                                                        </TabItem>
                                                        <TabItem Header="Windows">
                                                                <StackPanel Padding="6">
                                                                        <TextBlock Text="Select an application window" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                                                                        <ListBox x:Name="WindowList" Height="120" />
                                                                </StackPanel>
                                                        </TabItem>
                                                        <TabItem Header="Video Capture">
                                                                <StackPanel Padding="6">
                                                                        <TextBlock Text="Select a camera" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                                                                        <ListBox x:Name="CameraList" Height="120" />
                                                                </StackPanel>
                                                        </TabItem>
                                                </TabControl>
                                        </StackPanel>
                                </Border>
                        </Grid>

                        <!-- Vertical splitter between left and main -->
                        <GridSplitter Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                                                                Width="6" HorizontalAlignment="Right"
                                                                                Background="{StaticResource BorderDefaultBrush}" />

                        <!-- Main center area: Preview (left) and Program (right) -->
                        <Grid Grid.Row="0" Grid.Column="1" Margin="8">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Preview (left) -->
                                <Border Grid.Column="0" Background="{StaticResource BgSurfaceBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0" Padding="6">
                                        <StackPanel>
                                                <TextBlock Text="Preview" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <Border x:Name="PreviewArea" Background="#0D000000" Height="360" Margin="0,8,0,0"/>
                                        </StackPanel>
                                </Border>

                                <!-- Horizontal GridSplitter (between preview and program) -->
                                <GridSplitter Grid.Column="1" Width="6" Background="{StaticResource BorderDefaultBrush}" HorizontalAlignment="Stretch" />

                                <!-- Program (right) -->
                                <Border Grid.Column="2" Background="{StaticResource BgSurfaceBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1,0,0,0" Padding="6">
                                        <StackPanel>
                                                <TextBlock Text="Program" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <Border Background="#0D000000" Height="360" Margin="0,8,0,0">
                                                    <ContentControl x:Name="ContentPanel" />
                                                </Border>
                                        </StackPanel>
                                </Border>
                        </Grid>

                        <!-- Right column: small vertical preview / properties -->
                        <Border Grid.Row="0" Grid.Column="2" Margin="8" Background="{StaticResource BgSurfaceBrush}" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1,0,0,0" Padding="6">
                                <StackPanel>
                                        <TextBlock Text="Vertical" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <Border Height="200" Background="#0D000000" Margin="0,8,0,0" />
                                        <StackPanel Margin="0,8,0,0">
                                                <TextBlock Text="Properties" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="(contextual controls)" Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" />
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Horizontal splitter between main and bottom -->
                        <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                                                Height="6" VerticalAlignment="Top" Background="{StaticResource BorderDefaultBrush}" />

                        <!-- Bottom area: Audio Mixer (left) and Scene Transitions + Controls (right) -->
                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="8">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource BgSurfaceBrush}" Padding="8" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                        <StackPanel>
                                                <TextBlock Text="Audio Mixer" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <Border Height="120" Background="#0D000000" Margin="0,8,0,0" />
                                        </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="{StaticResource BgSurfaceBrush}" Padding="8" BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1,1,0,0">
                                        <StackPanel Spacing="8">
                                                <TextBlock Text="Scene Transitions" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                                <ComboBox x:Name="TransitionSelect" Width="180" />
                                                <TextBlock Text="Controls" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button x:Name="StartStreamingBtn" Content="Start Streaming" />
                                                        <Button x:Name="StopRecordingBtn" Content="Stop Recording" />
                                                        <Button x:Name="StudioModeBtn" Content="Studio Mode" />
                                                </StackPanel>
                                        </StackPanel>
                                </Border>
                        </Grid>
                </Grid>

    </Grid>
  </Grid>
</Window>
