<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RecordIt.Avalonia.Pages.SettingsPage"
             Background="{StaticResource BgBaseBrush}">

  <Grid RowDefinitions="Auto,*">

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
      <StackPanel Spacing="4">
        <TextBlock Text="Settings" Classes="page-title" />
        <TextBlock Text="Configure RecordIt to match your workflow"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="24,20">
      <StackPanel Spacing="24" MaxWidth="640">

        <!-- Appearance -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Appearance"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Theme" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Dark or light mode"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="ThemeCombo"
                        Classes="alvonia" Width="140">
                <ComboBoxItem Content="Dark" IsSelected="True" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="System" />
              </ComboBox>
            </Grid>

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Language" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="UI display language"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="LangCombo"
                        Classes="alvonia" Width="140">
                <ComboBoxItem Content="English" IsSelected="True" />
                <ComboBoxItem Content="Deutsch" />
                <ComboBoxItem Content="Français" />
                <ComboBoxItem Content="Español" />
                <ComboBoxItem Content="日本語" />
              </ComboBox>
            </Grid>

          </StackPanel>
        </Border>

        <!-- Recording -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Recording"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Output folder" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Where recordings are saved"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <Button Grid.Column="1" Classes="ghost"
                      Content="Browse…" Click="BrowseOutputBtn_Click"
                      Padding="12,6" />
            </Grid>

            <TextBox x:Name="OutputPathBox"
                     Background="{StaticResource BgElevatedBrush}"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     BorderBrush="{StaticResource BorderDefaultBrush}"
                     CornerRadius="8"
                     FontSize="12" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Output format" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="File container format"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="FormatCombo"
                        Classes="alvonia" Width="140">
                <ComboBoxItem Content="MP4 (H.264)" IsSelected="True" />
                <ComboBoxItem Content="MKV (H.264)" />
                <ComboBoxItem Content="WebM (VP9)" />
              </ComboBox>
            </Grid>

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Countdown before recording" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Delay in seconds before capture starts"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch x:Name="CountdownToggle"
                            IsChecked="True"
                            OnContent="" OffContent="" />
            </Grid>

          </StackPanel>
        </Border>

        <!-- Encoding -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Encoding"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <!-- Hardware encoding toggle -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Hardware Encoding" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Use GPU encoder (NVENC / AMF / QSV) instead of CPU libx264"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch x:Name="HardwareEncodingToggle"
                            Grid.Column="1"
                            IsChecked="False"
                            OnContent="" OffContent=""
                            IsCheckedChanged="HardwareEncodingToggle_Changed" />
            </Grid>

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <!-- GPU / Encoder dropdown -->
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="GPU / Encoder" FontSize="13"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock x:Name="EncoderStatusText"
                             Text="Detecting encoders…"
                             FontSize="12"
                             Foreground="{StaticResource TextTertiaryBrush}" />
                </StackPanel>
                <Button Grid.Column="2" Margin="8,0,0,0"
                        Classes="ghost" Content="Refresh"
                        Padding="12,6"
                        Click="RefreshEncoders_Click" />
              </Grid>

              <ComboBox x:Name="EncoderCombo"
                        IsEnabled="False"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="EncoderCombo_SelectionChanged"
                        Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- External Tools -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="External Tools"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <!-- FFmpeg label + inline status badge -->
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="FFmpeg Executable" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <Border x:Name="FfmpegStatusBadge"
                        CornerRadius="4" Padding="6,2"
                        IsVisible="False">
                  <TextBlock x:Name="FfmpegStatusText"
                             FontSize="11" FontWeight="Medium" />
                </Border>
              </StackPanel>
              <TextBlock FontSize="12" TextWrapping="Wrap"
                         Foreground="{StaticResource TextTertiaryBrush}">
                Full path to ffmpeg (or ffmpeg.exe on Windows).
                Leave blank to use the bundled binary or the system PATH.
                Required for recording, audio extraction and export presets.
              </TextBlock>
            </StackPanel>

            <!-- Path box + Browse + Verify -->
            <Grid ColumnDefinitions="*,Auto,Auto" >
              <TextBox x:Name="FfmpegPathBox"
                       Grid.Column="0"
                       Margin="0,0,6,0"
                       PlaceholderText="ffmpeg  (auto-detected if blank)"
                       FontFamily="Cascadia Code,Consolas,monospace"
                       FontSize="12"
                       LostFocus="FfmpegPath_LostFocus"
                       Background="{StaticResource BgElevatedBrush}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       BorderBrush="{StaticResource BorderDefaultBrush}"
                       CornerRadius="8" />
              <Button Grid.Column="1" Margin="0,0,6,0"
                      Classes="ghost" Content="Browse…"
                      Padding="12,6"
                      Click="FfmpegBrowse_Click" />
              <Button Grid.Column="2"
                      Classes="ghost" Content="Verify"
                      Padding="12,6"
                      Click="FfmpegVerify_Click" />
            </Grid>

            <!-- Install hint -->
            <TextBlock FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextTertiaryBrush}">
              Don't have FFmpeg?  Run "winget install Gyan.FFmpeg" (Windows) or
              "brew install ffmpeg" (macOS) / "sudo apt install ffmpeg" (Linux).
              The installer bundles FFmpeg automatically — no manual install needed.
            </TextBlock>

          </StackPanel>
        </Border>

        <!-- Cursor & Mouse Effects -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Cursor &amp; Mouse Effects"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Capture Mouse Cursor" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Include cursor in recordings" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Cursor Highlight" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Show colored circle around cursor" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Click Animation" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Show ripple on mouse clicks" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Smart Focus (Auto-Zoom)" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Zoom to mouse activity area" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="False" OnContent="" OffContent="" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Webcam Overlay -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Webcam Overlay"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Webcam Shape" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="PiP overlay shape" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="140">
                <ComboBoxItem Content="Rectangle" />
                <ComboBoxItem Content="Rounded" IsSelected="True" />
                <ComboBoxItem Content="Circle" />
              </ComboBox>
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Default Position" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Where to place webcam" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="140">
                <ComboBoxItem Content="Bottom Right" IsSelected="True" />
                <ComboBoxItem Content="Bottom Left" />
                <ComboBoxItem Content="Top Right" />
                <ComboBoxItem Content="Top Left" />
              </ComboBox>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Audio -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Audio"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Record System Audio" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Capture desktop audio" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Separate Audio Tracks" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Record mic and system as separate tracks" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="False" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Noise Suppression" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="AI-powered background noise removal" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Echo Cancellation" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Reduce echo from speakers" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Audio Bitrate" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Audio encoding quality" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="140">
                <ComboBoxItem Content="128 kbps" />
                <ComboBoxItem Content="192 kbps" IsSelected="True" />
                <ComboBoxItem Content="256 kbps" />
                <ComboBoxItem Content="320 kbps" />
              </ComboBox>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Encoder & Performance -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Encoder &amp; Performance"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Video Bitrate" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Target bitrate in kbps" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="160">
                <ComboBoxItem Content="4 Mbps (Low)" />
                <ComboBoxItem Content="6 Mbps" />
                <ComboBoxItem Content="8 Mbps (Recommended)" IsSelected="True" />
                <ComboBoxItem Content="12 Mbps" />
                <ComboBoxItem Content="20 Mbps (High)" />
              </ComboBox>
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Encoder Preset" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Quality vs performance" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="160">
                <ComboBoxItem Content="Fast (Low quality)" />
                <ComboBoxItem Content="Balanced" IsSelected="True" />
                <ComboBoxItem Content="Quality (Slow)" />
                <ComboBoxItem Content="Lossless" />
              </ComboBox>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Recording Behaviour -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Recording Behaviour"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Countdown Duration" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Seconds before recording starts" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ComboBox Grid.Column="1" Classes="alvonia" Width="120">
                <ComboBoxItem Content="None" />
                <ComboBoxItem Content="3 seconds" IsSelected="True" />
                <ComboBoxItem Content="5 seconds" />
                <ComboBoxItem Content="10 seconds" />
              </ComboBox>
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Pause/Resume Sound" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Play sound on pause/resume" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="Recording Indicator" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Red border on screen while recording" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent="" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Keyboard Shortcuts -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="16">
            <TextBlock Text="Keyboard Shortcuts"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <Border Height="1" Background="{StaticResource BorderDefaultBrush}" />

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Start / Stop Recording" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Padding="8,4">
                <TextBlock Text="Ctrl+Shift+R" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Pause Recording" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Padding="8,4">
                <TextBlock Text="Ctrl+Shift+P" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Open Whiteboard" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Padding="8,4">
                <TextBlock Text="Ctrl+Shift+W" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
              </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Take Screenshot" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Padding="8,4">
                <TextBlock Text="Ctrl+Shift+S" FontFamily="Cascadia Code,Consolas,monospace" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
              </Border>
            </Grid>

          </StackPanel>
        </Border>

        <!-- About -->
        <Border Classes="alvonia-card">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
              <Border Width="40" Height="40"
                      Background="{StaticResource BrandPrimaryBrush}"
                      CornerRadius="10">
                <TextBlock Text="R" Foreground="White"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <StackPanel Spacing="2">
                <TextBlock Text="RecordIt" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Avalonia Edition · v1.1.0"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" />
              </StackPanel>
            </StackPanel>
            <TextBlock Text="Powered by Alvonia UI design system. Built with Avalonia UI 11, .NET 10, and ffmpeg."
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <TextBlock Text="github.com/dotnetappdev/recordit"
                       FontSize="12"
                       Foreground="{StaticResource BrandPrimaryBrush}"
                       Cursor="Hand" />
          </StackPanel>
        </Border>

        <!-- Save button -->
        <Button Classes="primary"
                Content="Save Settings"
                Click="SaveBtn_Click"
                Padding="20,10"
                HorizontalAlignment="Left" />

      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
