<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RecordIt.Avalonia.Pages.RecordPage"
             Background="{StaticResource BgBaseBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />   <!-- Menu bar -->
      <RowDefinition Height="*"    />   <!-- Preview -->
      <RowDefinition Height="220"  />   <!-- Docks -->
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════════════════════════════════════
         Row 0 · Menu Bar
    ═══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderPanelBrush}"
            BorderThickness="0,0,0,1">
      <Menu Background="Transparent" FontSize="13">

        <!-- File -->
        <MenuItem Header="File">
          <MenuItem x:Name="MenuNewScene"    Header="New Scene Collection"   Click="MenuNewScene_Click" />
          <MenuItem x:Name="MenuOpenScene"   Header="Open Scene Collection…" Click="MenuOpenScene_Click" />
          <Separator />
          <MenuItem x:Name="MenuStartRecord" Header="Start Recording"        Click="StartRecordBtn_Click" />
          <MenuItem x:Name="MenuStopRecord"  Header="Stop Recording"         Click="StopRecordBtn_Click" IsEnabled="False" />
          <Separator />
          <MenuItem x:Name="MenuExport"      Header="Show in Library"        Click="MenuExport_Click" />
          <Separator />
          <MenuItem x:Name="MenuExit"        Header="Exit"                   Click="MenuExit_Click" />
        </MenuItem>

        <!-- Edit -->
        <MenuItem Header="Edit">
          <MenuItem Header="Settings…"    Click="MenuSettings_Click" />
          <Separator />
          <MenuItem Header="Add Scene"    Click="AddSceneBtn_Click" />
          <MenuItem Header="Add Source…"  Click="AddSourceBtn_Click" />
        </MenuItem>

        <!-- View -->
        <MenuItem Header="View">
          <MenuItem Header="Fullscreen Preview" Click="MenuFullscreen_Click" />
          <Separator />
          <MenuItem x:Name="MenuShowScenes"      Header="Scenes Panel"    IsChecked="True" />
          <MenuItem x:Name="MenuShowSources"     Header="Sources Panel"   IsChecked="True" />
          <MenuItem x:Name="MenuShowMixer"       Header="Audio Mixer"     IsChecked="True" />
          <MenuItem x:Name="MenuShowTransitions" Header="Options Panel"   IsChecked="True" />
          <MenuItem x:Name="MenuShowControls"    Header="Controls Panel"  IsChecked="True" />
        </MenuItem>

        <!-- Docks -->
        <MenuItem Header="Docks">
          <MenuItem Header="Reset Dock Layout"   Click="MenuResetLayout_Click" />
          <Separator />
          <MenuItem Header="Refresh Sources"     Click="RefreshSourcesBtn_Click" />
          <MenuItem Header="Probe Audio Devices" Click="ProbeDevicesBtn_Click" />
        </MenuItem>

        <!-- Tools -->
        <MenuItem Header="Tools">
          <MenuItem Header="Whiteboard"    Click="MenuWhiteboard_Click" />
          <MenuItem Header="Library"       Click="MenuLibrary_Click" />
          <Separator />
          <MenuItem Header="Start Preview" Click="StartPreviewBtn_Click" />
          <MenuItem Header="Stop Preview"  Click="StopPreviewBtn_Click" />
        </MenuItem>

        <!-- Help -->
        <MenuItem Header="Help">
          <MenuItem Header="About RecordIt" Click="MenuAbout_Click" />
        </MenuItem>

      </Menu>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════
         Row 1 · Preview Area
    ═══════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Background="#080808">

      <!-- Preview host -->
      <Border x:Name="PreviewHost"
              Background="#000000"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
        <Grid>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="⏺"
                       FontSize="36" Foreground="#22FFFFFF"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="PreviewHintText"
                       Text="No source selected"
                       FontSize="13" FontWeight="Medium"
                       Foreground="#33FFFFFF"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Preview label (top-left) -->
      <Border HorizontalAlignment="Left" VerticalAlignment="Top"
              Margin="12,10" Padding="10,4"
              Background="#CC000000"
              CornerRadius="6"
              BorderBrush="#22FFFFFF" BorderThickness="1">
        <TextBlock Text="PREVIEW"
                   FontSize="10" FontWeight="Bold"
                   Foreground="#AAFFFFFF"
                   LetterSpacing="0.8" />
      </Border>

      <!-- Recording badge (top-right) -->
      <Border x:Name="RecordingBadge"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,10,12,0" Padding="10,4"
              Background="#CC1A0000"
              CornerRadius="6"
              BorderBrush="#55EF4444" BorderThickness="1"
              IsVisible="False">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="#EF4444" />
          <TextBlock x:Name="RecordingTimerText"
                     Text="00:00"
                     FontSize="11" FontWeight="Bold"
                     Foreground="#EF4444"
                     FontFamily="Cascadia Code,Consolas,monospace" />
        </StackPanel>
      </Border>

      <!-- Scene quick-bar (bottom of preview) -->
      <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
              Background="#CC000000" Padding="12,6"
              BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled">
          <StackPanel x:Name="SceneQuickBar"
                      Orientation="Horizontal" Spacing="6" />
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         Row 2 · Docked Panels
    ═══════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="2"
          Background="{StaticResource BgPanelBrush}"
          BorderBrush="{StaticResource BorderPanelBrush}"
          BorderThickness="0,1,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="ScenesColumn"   Width="175" MinWidth="100" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition x:Name="SourcesColumn"  Width="200" MinWidth="120" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition x:Name="MixerColumn"    Width="*"   MinWidth="200" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition x:Name="OptionsColumn"  Width="155" MinWidth="100" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition x:Name="ControlsColumn" Width="155" MinWidth="130" />
      </Grid.ColumnDefinitions>

      <!-- ── Panel: Scenes ─────────────────────────────────────────── -->
      <Grid x:Name="ScenesPanel" Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Classes="obs-panel-header">
          <TextBlock Text="SCENES" Classes="panel-header" VerticalAlignment="Center" />
        </Border>

        <ListBox Grid.Row="1"
                 x:Name="ScenesList"
                 Background="Transparent"
                 SelectionChanged="ScenesList_SelectionChanged"
                 Padding="2">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background"  Value="Transparent" />
              <Setter Property="Padding"     Value="8,5" />
              <Setter Property="CornerRadius" Value="6" />
              <Setter Property="Margin"      Value="4,1" />
              <Setter Property="MinHeight"   Value="28" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"
                         FontSize="12"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Classes="obs-panel-toolbar">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="obs-toolbar" Click="AddSceneBtn_Click"    ToolTip.Tip="Add Scene"    Content="+" />
            <Button Classes="obs-toolbar" Click="RemoveSceneBtn_Click" ToolTip.Tip="Remove Scene" Content="−" />
            <Button Classes="obs-toolbar" Click="SceneUpBtn_Click"     ToolTip.Tip="Move Up"      Content="▲" FontSize="9" />
            <Button Classes="obs-toolbar" Click="SceneDownBtn_Click"   ToolTip.Tip="Move Down"    Content="▼" FontSize="9" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Separator -->
      <Rectangle Grid.Column="1" Fill="{StaticResource BorderPanelBrush}" Width="1" Opacity="0.7" />

      <!-- ── Panel: Sources ────────────────────────────────────────── -->
      <Grid x:Name="SourcesPanel" Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Classes="obs-panel-header">
          <TextBlock Text="SOURCES" Classes="panel-header" VerticalAlignment="Center" />
        </Border>

        <ListBox Grid.Row="1"
                 x:Name="SourcesList"
                 Background="Transparent"
                 SelectionChanged="SourcesList_SelectionChanged"
                 Padding="2">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background"  Value="Transparent" />
              <Setter Property="Padding"     Value="8,5" />
              <Setter Property="CornerRadius" Value="6" />
              <Setter Property="Margin"      Value="4,1" />
              <Setter Property="MinHeight"   Value="28" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           Text="{Binding IconText}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="👁" FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="3"
                           Text="🔒" FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Classes="obs-panel-toolbar">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="obs-toolbar" Click="AddSourceBtn_Click"      ToolTip.Tip="Add Source"     Content="+" />
            <Button Classes="obs-toolbar" Click="RemoveSourceBtn_Click"   ToolTip.Tip="Remove Source"  Content="−" />
            <Button Classes="obs-toolbar" Click="SourceUpBtn_Click"       ToolTip.Tip="Move Up"        Content="▲" FontSize="9" />
            <Button Classes="obs-toolbar" Click="SourceDownBtn_Click"     ToolTip.Tip="Move Down"      Content="▼" FontSize="9" />
            <Button Classes="obs-toolbar" Click="SourceSettingsBtn_Click" ToolTip.Tip="Source Settings" Content="⚙" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Separator -->
      <Rectangle Grid.Column="3" Fill="{StaticResource BorderPanelBrush}" Width="1" Opacity="0.7" />

      <!-- ── Panel: Audio Mixer ─────────────────────────────────────── -->
      <Grid x:Name="MixerPanel" Grid.Column="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Classes="obs-panel-header">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="AUDIO MIXER" Classes="panel-header" VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="obs-toolbar"
                    Click="ProbeDevicesBtn_Click"
                    ToolTip.Tip="Refresh audio devices"
                    Height="18" Width="18"
                    Content="↻" />
          </Grid>
        </Border>

        <!-- Mixer channels — populated from code-behind -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="6,4">
          <StackPanel x:Name="AudioMixerChannels"
                      Orientation="Horizontal"
                      Spacing="2" />
        </ScrollViewer>

        <Border Grid.Row="2" Classes="obs-panel-toolbar">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="obs-toolbar" Click="AddAudioTrackBtn_Click"    ToolTip.Tip="Add audio source"       Content="+" />
            <Button Classes="obs-toolbar" Click="ClearAudioTracksBtn_Click" ToolTip.Tip="Remove all audio sources" Content="✕" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Separator -->
      <Rectangle Grid.Column="5" Fill="{StaticResource BorderPanelBrush}" Width="1" Opacity="0.7" />

      <!-- ── Panel: Options ─────────────────────────────────────────── -->
      <Grid x:Name="OptionsPanel" Grid.Column="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Classes="obs-panel-header">
          <TextBlock Text="OPTIONS" Classes="panel-header" VerticalAlignment="Center" />
        </Border>

        <ScrollViewer Grid.Row="1" Padding="8,6">
          <StackPanel Spacing="10">

            <StackPanel Spacing="3">
              <TextBlock Text="RESOLUTION" Classes="section-label" />
              <ComboBox x:Name="QualityCombo"
                        Classes="alvonia"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0">
                <ComboBoxItem Content="1080p (1920×1080)" />
                <ComboBoxItem Content="1440p (2560×1440)" />
                <ComboBoxItem Content="4K (3840×2160)" />
                <ComboBoxItem Content="720p (1280×720)" />
                <ComboBoxItem Content="480p (854×480)" />
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Text="FRAME RATE" Classes="section-label" />
              <ComboBox x:Name="FpsCombo"
                        Classes="alvonia"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="1">
                <ComboBoxItem Content="60 fps" />
                <ComboBoxItem Content="30 fps" />
                <ComboBoxItem Content="24 fps" />
                <ComboBoxItem Content="15 fps" />
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Text="CAMERA OVERLAY" Classes="section-label" />
              <ComboBox x:Name="WebcamDeviceCombo"
                        Classes="alvonia"
                        HorizontalAlignment="Stretch">
                <ComboBoxItem Content="(disabled)" IsSelected="True" />
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="3">
              <TextBlock Text="MIC / AUDIO INPUT" Classes="section-label" />
              <ComboBox x:Name="MicDeviceCombo"
                        Classes="alvonia"
                        HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Default Microphone" IsSelected="True" />
              </ComboBox>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- Separator -->
      <Rectangle Grid.Column="7" Fill="{StaticResource BorderPanelBrush}" Width="1" Opacity="0.7" />

      <!-- ── Panel: Controls ────────────────────────────────────────── -->
      <Grid x:Name="ControlsPanel" Grid.Column="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Classes="obs-panel-header">
          <TextBlock Text="CONTROLS" Classes="panel-header" VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Row="1" Padding="8,8" Spacing="6">

          <Button x:Name="StartRecordBtn"
                  Classes="record"
                  Click="StartRecordBtn_Click">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center" />
              <TextBlock Text="Start Recording" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <Button x:Name="StopRecordBtn"
                  Classes="controls-panel"
                  Click="StopRecordBtn_Click"
                  IsVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <TextBlock Text="⏹" FontSize="11" Foreground="{StaticResource RecordingBrush}" />
              <TextBlock Text="Stop Recording" />
            </StackPanel>
          </Button>

          <Button x:Name="StartPreviewBtn"
                  Classes="controls-panel"
                  Click="StartPreviewBtn_Click">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="▶" FontSize="11" />
              <TextBlock Text="Start Preview" />
            </StackPanel>
          </Button>

          <Button x:Name="StopPreviewBtn"
                  Classes="controls-panel"
                  Click="StopPreviewBtn_Click"
                  IsVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="⏸" FontSize="11" />
              <TextBlock Text="Stop Preview" />
            </StackPanel>
          </Button>

          <!-- Divider -->
          <Border Height="1"
                  Background="{StaticResource BorderDefaultBrush}"
                  Margin="0,2" />

          <Button Classes="controls-panel" Click="MenuSettings_Click">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="⚙" FontSize="11" />
              <TextBlock Text="Settings" />
            </StackPanel>
          </Button>

          <Button Classes="controls-panel" Click="ExportBtn_Click">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="📁" FontSize="11" />
              <TextBlock Text="Open Library" />
            </StackPanel>
          </Button>

          <TextBlock x:Name="StatusText"
                     Text="Ready"
                     FontSize="11"
                     Foreground="{StaticResource TextTertiaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>
      </Grid>

    </Grid>
  </Grid>
</UserControl>
